---
interface FeatureItem {
  label: string;
}

interface Props {
  items?: FeatureItem[];
}

const { items = [] } = Astro.props;
const icons = ['cube', 'print', 'bag', 'leaf'];
---
{items.length > 0 && (
  <div class="hero-feature-strip" aria-label="Packaging features">
    {items.slice(0, 4).map((item, index) => (
      <div class="hero-feature-item">
        <svg class="hero-feature-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          {icons[index] === 'cube' && (
            <>
              <path d="m24 5 16 9-16 9-16-9 16-9z" />
              <path d="M8 14v20l16 9 16-9V14" />
              <path d="M24 23v20" />
            </>
          )}
          {icons[index] === 'print' && (
            <>
              <rect x="11" y="9" width="26" height="30" rx="2" />
              <path d="m17 29 7-16 7 16" />
              <path d="M20 24h8" />
            </>
          )}
          {icons[index] === 'bag' && (
            <>
              <path d="M13 18h22l3 23H10l3-23z" />
              <path d="M18 18a6 6 0 0 1 12 0" />
            </>
          )}
          {icons[index] === 'leaf' && (
            <>
              <path d="M38 8c-15 1-25 10-27 28 17-1 26-10 27-28z" />
              <path d="M12 36 32 16" />
            </>
          )}
        </svg>
        <span>{item.label}</span>
      </div>
    ))}
  </div>
)}

<style>
  .hero-feature-strip {
    position: absolute;
    left: 2.55%;
    bottom: 3.75%;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: start;
    gap: 1.4%;
    width: 33.5%;
    min-width: 21rem;
    padding: 1.05% 1.1% 1.1%;
    background: #fff;
  }

  .hero-feature-item {
    display: grid;
    grid-template-rows: clamp(2.1rem, 3.35vw, 4.2rem) clamp(2.2rem, 2.55vw, 3.1rem);
    justify-items: center;
    align-items: center;
    min-width: 0;
    color: #d69a00;
    text-align: center;
  }

  .hero-feature-icon {
    width: clamp(1.95rem, 3.05vw, 3.85rem);
    height: clamp(1.95rem, 3.05vw, 3.85rem);
  }

  .hero-feature-item span {
    display: grid;
    min-height: 2.2em;
    max-width: 5.5em;
    place-items: center;
    color: #222;
    font-family: Archivo, Inter, system-ui, sans-serif;
    font-size: clamp(0.62rem, 0.92vw, 1.15rem);
    font-weight: 800;
    line-height: 1.05;
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .hero-feature-strip {
      left: 2.3%;
      bottom: 3.2%;
      width: 36%;
      min-width: 0;
      padding: 0.6% 0.6% 0.7%;
    }

    .hero-feature-item {
      grid-template-rows: 1.15rem 1.25rem;
    }

    .hero-feature-icon {
      width: 1rem;
      height: 1rem;
    }

    .hero-feature-item span {
      font-size: clamp(0.3rem, 1.35vw, 0.45rem);
    }
  }
</style>
