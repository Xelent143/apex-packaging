---
interface Props {
  eyebrow?: string;
  heading: string;
  lead?: string;
}
const { eyebrow, heading, lead } = Astro.props;
---
<section class="pt-20 md:pt-28 pb-12 md:pb-16 border-b border-neutral-200">
  <div class="container max-w-wide">
    {eyebrow && <p class="eyebrow mb-5">{eyebrow}</p>}
    <h1 class="font-display font-bold text-4xl md:text-6xl lg:text-7xl text-neutral-900 leading-[1.05] tracking-tight max-w-4xl mb-6">
      {heading}
    </h1>
    {lead && <p class="text-lg md:text-xl text-neutral-600 leading-relaxed max-w-3xl">{lead}</p>}
  </div>
</section>
