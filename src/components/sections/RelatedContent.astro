---
interface Props {
  heading?: string;
  items: Array<{ title: string; href: string; description?: string }>;
}
const { heading = 'Related', items } = Astro.props;
---
<section class="py-16 md:py-20">
  <div class="container max-w-wide">
    <h2 class="font-display font-bold text-2xl md:text-3xl text-neutral-900 mb-8">{heading}</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {items.map((it) => (
        <a href={it.href} class="block p-6 border border-neutral-200 rounded-lg hover:border-accent transition-colors">
          <h3 class="font-display font-semibold text-lg text-neutral-900 mb-2">{it.title}</h3>
          {it.description && <p class="text-sm text-neutral-600 leading-relaxed">{it.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
