---
interface Props {
  heading?: string;
  items: Array<{ title: string; href: string; description?: string }>;
}
const { heading = 'Related', items } = Astro.props;
---
<section class="py-12 md:py-20">
  <div class="container max-w-wide">
    <h2 class="mb-6 font-display text-2xl font-bold text-neutral-900 md:mb-8 md:text-3xl">{heading}</h2>
    <div class="-mx-4 flex snap-x gap-4 overflow-x-auto px-4 pb-2 [scrollbar-width:none] md:mx-0 md:grid md:grid-cols-3 md:gap-6 md:overflow-visible md:px-0 md:pb-0 [&::-webkit-scrollbar]:hidden">
      {items.map((it) => (
        <a href={it.href} class="block min-h-[10rem] w-[82vw] max-w-[22rem] shrink-0 snap-start rounded-md border border-neutral-200 bg-white p-5 transition-colors hover:border-accent md:min-h-0 md:w-auto md:max-w-none md:p-6">
          <h3 class="mb-2 font-display text-lg font-semibold text-neutral-900">{it.title}</h3>
          {it.description && <p class="text-sm text-neutral-600 leading-relaxed">{it.description}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
