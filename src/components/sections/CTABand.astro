---
interface Props {
  heading: string;
  lead?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}
const { heading, lead, primaryCta, secondaryCta } = Astro.props;
---
<section class="bg-neutral-900 py-12 text-neutral-50 md:py-28">
  <div class="container max-w-default text-center">
    <h2 class="mb-4 font-display text-3xl font-bold leading-[1.05] text-neutral-50 md:mb-5 md:text-5xl">{heading}</h2>
    {lead && <p class="mx-auto mb-7 max-w-2xl text-base leading-relaxed text-neutral-400 md:mb-8 md:text-lg">{lead}</p>}
    <div class="flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:flex-wrap sm:items-center md:gap-4">
      <a href={primaryCta.href} class="inline-flex items-center gap-2 bg-accent text-neutral-900 px-7 py-3.5 rounded-md font-medium hover:bg-warning transition-colors">
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="inline-flex items-center gap-2 bg-transparent text-neutral-50 px-7 py-3.5 rounded-md font-medium border-2 border-neutral-700 hover:border-neutral-50 transition-colors">
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
