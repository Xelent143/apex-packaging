---
interface Props {
  heading?: string;
  faqs: Array<{ q: string; a: string }>;
}
const { heading = 'Frequently asked', faqs } = Astro.props;
---
<section class="py-20 md:py-28">
  <div class="container max-w-default">
    <h2 class="font-display font-bold text-3xl md:text-5xl text-neutral-900 mb-10 leading-[1.05]">{heading}</h2>
    <div class="divide-y divide-neutral-200 border-t border-b border-neutral-200">
      {faqs.map((faq) => (
        <details class="group py-5">
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
            <span class="font-display font-semibold text-lg md:text-xl text-neutral-900 group-hover:text-accent transition-colors">{faq.q}</span>
            <span class="text-accent font-mono text-xl flex-none mt-1 group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="mt-4 text-neutral-600 leading-relaxed text-[0.9375rem] max-w-3xl">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
