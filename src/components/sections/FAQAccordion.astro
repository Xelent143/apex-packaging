---
interface Props {
  heading?: string;
  faqs: Array<{ q: string; a: string }>;
}
const { heading = 'Frequently asked', faqs } = Astro.props;
---
<section class="py-12 md:py-28">
  <div class="container max-w-default">
    <h2 class="mb-7 font-display text-3xl font-bold leading-[1.05] text-neutral-900 md:mb-10 md:text-5xl">{heading}</h2>
    <div class="divide-y divide-neutral-200 overflow-hidden rounded-md border border-neutral-200 bg-white md:rounded-none md:border-x-0">
      {faqs.map((faq) => (
        <details class="group">
          <summary class="flex min-h-[4.25rem] cursor-pointer list-none items-start justify-between gap-4 px-4 py-5 md:px-0">
            <span class="font-display text-base font-semibold text-neutral-900 transition-colors group-hover:text-accent md:text-xl">{faq.q}</span>
            <span class="mt-0.5 flex-none font-mono text-xl text-accent transition-transform group-open:rotate-45 md:mt-1">+</span>
          </summary>
          <p class="max-w-3xl px-4 pb-5 text-[0.9375rem] leading-relaxed text-neutral-600 md:px-0">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
