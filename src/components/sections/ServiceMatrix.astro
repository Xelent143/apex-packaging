---
interface ServiceCard {
  title: string;
  href: string;
  meta?: string;
  description: string;
  bullets?: string[];
  image?: {
    src: string;
    alt: string;
    width: number;
    height: number;
  };
}
interface Props {
  eyebrow?: string;
  heading: string;
  lead?: string;
  services: ServiceCard[];
}
const { eyebrow, heading, lead, services } = Astro.props;
---
<section class="py-20 md:py-32">
  <div class="container max-w-wide">
    <div class="max-w-2xl mb-14">
      {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
      <h2 class="font-display font-bold text-3xl md:text-5xl text-neutral-900 leading-[1.05] mb-5">{heading}</h2>
      {lead && <p class="text-lg text-neutral-600 leading-relaxed">{lead}</p>}
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {services.map((s, i) => (
        <a
          href={s.href}
          class="group relative flex flex-col overflow-hidden bg-neutral-50 border border-neutral-200 hover:border-accent rounded-md transition-all hover:shadow-card"
        >
          {s.image && (
            <img
              src={s.image.src}
              alt={s.image.alt}
              width={s.image.width}
              height={s.image.height}
              loading="lazy"
              decoding="async"
              class="aspect-[3/2] w-full object-cover border-b border-neutral-200"
            />
          )}
          <div class="flex flex-1 flex-col p-7 md:p-8">
            <div class="flex items-baseline gap-3 mb-5">
              <span class="font-mono text-xs text-accent font-medium">0{i + 1}</span>
              {s.meta && <span class="text-xs text-neutral-500">{s.meta}</span>}
            </div>
            <h3 class="font-display font-semibold text-2xl text-neutral-900 mb-3 group-hover:text-accent transition-colors">{s.title}</h3>
            <p class="text-neutral-600 text-[0.9375rem] leading-relaxed mb-5 flex-1">{s.description}</p>
            {s.bullets && s.bullets.length > 0 && (
              <ul class="space-y-1.5 mb-6 text-sm text-neutral-500">
                {s.bullets.map((b) => <li class="pl-4 relative before:content-['—'] before:absolute before:left-0 before:text-accent">{b}</li>)}
              </ul>
            )}
            <span class="text-sm font-semibold text-neutral-900 inline-flex items-center gap-1">
              View specs →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
