---
interface ServiceCard {
  title: string;
  href: string;
  meta?: string;
  description: string;
  bullets?: string[];
  image?: {
    src: string;
    alt: string;
    width: number;
    height: number;
  };
}
interface Props {
  eyebrow?: string;
  heading: string;
  lead?: string;
  services: ServiceCard[];
}
const { eyebrow, heading, lead, services } = Astro.props;
---
<section class="py-12 md:py-32">
  <div class="container max-w-wide">
    <div class="mb-8 max-w-2xl md:mb-14">
      {eyebrow && <p class="eyebrow mb-3 md:mb-4">{eyebrow}</p>}
      <h2 class="mb-4 font-display text-3xl font-bold leading-[1.05] text-neutral-900 md:mb-5 md:text-5xl">{heading}</h2>
      {lead && <p class="text-base leading-relaxed text-neutral-600 md:text-lg">{lead}</p>}
    </div>
    <div class="grid gap-4 md:grid-cols-2 md:gap-8 lg:grid-cols-3">
      {services.map((s, i) => (
        <a
          href={s.href}
          class="group relative flex min-h-[13rem] flex-col overflow-hidden rounded-md border border-neutral-200 bg-neutral-50 transition-all hover:border-accent hover:shadow-card"
        >
          {s.image && (
            <img
              src={s.image.src}
              alt={s.image.alt}
              width={s.image.width}
              height={s.image.height}
              loading="lazy"
              decoding="async"
              class="aspect-[3/2] w-full object-cover border-b border-neutral-200"
            />
          )}
          <div class="flex flex-1 flex-col p-5 md:p-8">
            <div class="mb-4 flex items-baseline gap-3 md:mb-5">
              <span class="font-mono text-xs text-accent font-medium">0{i + 1}</span>
              {s.meta && <span class="text-xs text-neutral-500">{s.meta}</span>}
            </div>
            <h3 class="mb-3 font-display text-xl font-semibold text-neutral-900 transition-colors group-hover:text-accent md:text-2xl">{s.title}</h3>
            <p class="mb-5 flex-1 text-[0.9375rem] leading-relaxed text-neutral-600">{s.description}</p>
            {s.bullets && s.bullets.length > 0 && (
              <ul class="space-y-1.5 mb-6 text-sm text-neutral-500">
                {s.bullets.map((b) => <li class="pl-4 relative before:content-['—'] before:absolute before:left-0 before:text-accent">{b}</li>)}
              </ul>
            )}
            <span class="inline-flex min-h-11 items-center gap-1 rounded-md bg-white px-3 text-sm font-semibold text-neutral-900 ring-1 ring-neutral-200 md:bg-transparent md:px-0 md:ring-0">
              View specs →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
