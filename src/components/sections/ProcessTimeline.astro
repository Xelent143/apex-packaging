---
interface Props {
  eyebrow?: string;
  heading: string;
  steps: Array<{ title: string; description: string; meta?: string }>;
}
const { eyebrow, heading, steps } = Astro.props;
---
<section class="bg-neutral-100/60 py-12 md:py-32">
  <div class="container max-w-wide">
    <div class="mb-8 max-w-2xl md:mb-14">
      {eyebrow && <p class="eyebrow mb-3 md:mb-4">{eyebrow}</p>}
      <h2 class="font-display text-3xl font-bold leading-[1.05] text-neutral-900 md:text-5xl">{heading}</h2>
    </div>
    <ol class="grid gap-3 overflow-hidden rounded-lg md:grid-cols-2 md:gap-px md:bg-neutral-200 lg:grid-cols-3">
      {steps.map((s, i) => (
        <li class="rounded-md border border-neutral-200 bg-neutral-50 p-5 md:rounded-none md:border-0 md:p-10">
          <div class="mb-4 flex items-baseline gap-4">
            <span class="font-display text-3xl font-bold leading-none text-accent md:text-4xl">0{i + 1}</span>
            {s.meta && <span class="font-mono text-xs text-neutral-500">{s.meta}</span>}
          </div>
          <h3 class="mb-3 font-display text-xl font-semibold text-neutral-900">{s.title}</h3>
          <p class="text-[0.9375rem] text-neutral-600 leading-relaxed">{s.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
