---
interface Props {
  eyebrow?: string;
  heading: string;
  steps: Array<{ title: string; description: string; meta?: string }>;
}
const { eyebrow, heading, steps } = Astro.props;
---
<section class="py-20 md:py-32 bg-neutral-100/60">
  <div class="container max-w-wide">
    <div class="max-w-2xl mb-14">
      {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
      <h2 class="font-display font-bold text-3xl md:text-5xl text-neutral-900 leading-[1.05]">{heading}</h2>
    </div>
    <ol class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-200 rounded-lg overflow-hidden">
      {steps.map((s, i) => (
        <li class="bg-neutral-50 p-8 md:p-10">
          <div class="flex items-baseline gap-4 mb-4">
            <span class="font-display font-bold text-4xl text-accent leading-none">0{i + 1}</span>
            {s.meta && <span class="font-mono text-xs text-neutral-500">{s.meta}</span>}
          </div>
          <h3 class="font-display font-semibold text-xl text-neutral-900 mb-3">{s.title}</h3>
          <p class="text-[0.9375rem] text-neutral-600 leading-relaxed">{s.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
