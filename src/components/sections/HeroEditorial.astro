---
interface Props {
  eyebrow?: string;
  heading: string;
  lead: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  stats?: Array<{ value: string; label: string }>;
  media?: {
    src: string;
    alt: string;
    width: number;
    height: number;
  };
}
const { eyebrow, heading, lead, primaryCta, secondaryCta, stats = [], media } = Astro.props;
---
<section class="relative overflow-hidden border-b border-neutral-200 bg-neutral-50">
  <div class="container max-w-wide py-10 md:py-24 lg:py-32">
    <div class="grid gap-8 md:grid-cols-12 md:gap-10 lg:gap-14 items-center">
      <div class:list={[media ? 'md:col-span-6' : 'md:col-span-8']}>
        {eyebrow && <p class="eyebrow mb-4 md:mb-5">{eyebrow}</p>}
        <h1 class="mb-5 font-display text-[2.35rem] font-bold leading-[1.03] tracking-normal text-neutral-900 md:mb-7 md:text-6xl lg:text-7xl">
          {heading}
        </h1>
        <p class="mb-7 max-w-2xl text-base leading-relaxed text-neutral-600 md:mb-9 md:text-xl">
          {lead}
        </p>
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center md:gap-4">
          <a href={primaryCta.href} class="btn-primary text-base">{primaryCta.label}</a>
          {secondaryCta && <a href={secondaryCta.href} class="btn-secondary text-base">{secondaryCta.label}</a>}
        </div>
      </div>
      {media ? (
        <div class="md:col-span-6">
          <figure class="relative">
            <img
              src={media.src}
              alt={media.alt}
              width={media.width}
              height={media.height}
              class="h-auto w-full rounded-md border border-neutral-200 shadow-card"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
          {stats.length > 0 && (
            <div class="mt-4 grid grid-cols-3 gap-2 md:mt-6 md:gap-3">
              {stats.map((s) => (
                <div class="rounded-md border border-neutral-200 bg-white p-3 md:border-l-2 md:border-r-0 md:border-y-0 md:border-accent md:bg-transparent md:py-1 md:pl-4">
                  <div class="mb-1 font-display text-xl font-bold leading-none text-neutral-900 md:mb-2 md:text-3xl">{s.value}</div>
                  <div class="text-[0.68rem] leading-snug text-neutral-500 md:text-xs">{s.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      ) : stats.length > 0 && (
        <div class="grid grid-cols-2 gap-3 md:col-span-4 md:grid-cols-1 md:gap-6">
          {stats.map((s) => (
            <div class="rounded-md border border-neutral-200 bg-white p-4 md:border-l-2 md:border-r-0 md:border-y-0 md:border-accent md:bg-transparent md:py-1 md:pl-5">
              <div class="mb-2 font-display text-2xl font-bold leading-none text-neutral-900 md:text-4xl">{s.value}</div>
              <div class="text-xs leading-snug text-neutral-500 md:text-sm">{s.label}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
