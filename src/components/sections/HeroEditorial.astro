---
interface Props {
  eyebrow?: string;
  heading: string;
  lead: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  stats?: Array<{ value: string; label: string }>;
  media?: {
    src: string;
    alt: string;
    width: number;
    height: number;
  };
}
const { eyebrow, heading, lead, primaryCta, secondaryCta, stats = [], media } = Astro.props;
---
<section class="relative overflow-hidden bg-neutral-50 border-b border-neutral-200">
  <div class="container max-w-wide py-16 md:py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-10 lg:gap-14 items-center">
      <div class:list={[media ? 'md:col-span-6' : 'md:col-span-8']}>
        {eyebrow && <p class="eyebrow mb-5">{eyebrow}</p>}
        <h1 class="font-display font-bold text-4xl md:text-6xl lg:text-7xl leading-[1.02] text-neutral-900 mb-7 tracking-tight">
          {heading}
        </h1>
        <p class="text-lg md:text-xl text-neutral-600 leading-relaxed max-w-2xl mb-9">
          {lead}
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a href={primaryCta.href} class="btn-primary text-base">{primaryCta.label}</a>
          {secondaryCta && <a href={secondaryCta.href} class="btn-secondary text-base">{secondaryCta.label}</a>}
        </div>
      </div>
      {media ? (
        <div class="md:col-span-6">
          <figure class="relative">
            <img
              src={media.src}
              alt={media.alt}
              width={media.width}
              height={media.height}
              class="w-full h-auto rounded-md border border-neutral-200 shadow-card"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
          {stats.length > 0 && (
            <div class="mt-6 grid grid-cols-3 gap-3">
              {stats.map((s) => (
                <div class="border-l-2 border-accent pl-4 py-1">
                  <div class="font-display font-bold text-2xl md:text-3xl text-neutral-900 leading-none mb-2">{s.value}</div>
                  <div class="text-xs text-neutral-500 leading-snug">{s.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>
      ) : stats.length > 0 && (
        <div class="md:col-span-4 grid grid-cols-2 md:grid-cols-1 gap-6">
          {stats.map((s) => (
            <div class="border-l-2 border-accent pl-5 py-1">
              <div class="font-display font-bold text-3xl md:text-4xl text-neutral-900 leading-none mb-2">{s.value}</div>
              <div class="text-sm text-neutral-500 leading-snug">{s.label}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
