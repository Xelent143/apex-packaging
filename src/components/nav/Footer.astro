---
import { siteConfig } from '../../site.config';

const phoneDisplay = siteConfig.phoneDisplay ?? siteConfig.phone;
const phoneHref = siteConfig.phoneHref ?? `tel:${siteConfig.phone}`;

const footerGroups = [
  {
    title: 'Products',
    links: [
      ['Rigid Boxes', '/industries/rigid-boxes'],
      ['Corrugated Boxes', '/services/corrugated-boxes'],
      ['Mailer Boxes', '/services/mailer-boxes'],
      ['Pouches & Bags', '/industries/custom-mylar-bags'],
      ['Custom Printed Boxes', '/industries/custom-tuck-boxes'],
      ['CBD Packaging', '/services/cbd-boxes']
    ]
  },
  {
    title: 'Solutions',
    links: [
      ['By Industry', '/industries'],
      ['By Material', '/services'],
      ['By Style', '/services/mailer-boxes'],
      ['Custom Design', '/design-support'],
      ['Sustainable Packaging', '/sustainability'],
      ['Low Minimums', '/contact']
    ]
  },
  {
    title: 'Company',
    links: [
      ['About Us', '/about'],
      ['Design Support', '/design-support'],
      ['Quality Assurance', '/services'],
      ['Blog', '/blog'],
      ['Contact Us', '/contact'],
      ['Pay Now', '/paynow']
    ]
  }
];

const socialLinks = [
  { label: 'LinkedIn', image: '/images/footer-icons/social/linkedin.png' },
  { label: 'YouTube', image: '/images/footer-icons/social/youtube.png' },
  { label: 'Instagram', image: '/images/footer-icons/social/instagram.png' }
];
---

<footer class="border-t border-white/10 bg-[#041526] text-white">
  <div class="container max-w-wide py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.25fr_2.2fr_1.15fr] lg:gap-14">
      <div>
        <a href="/" class="inline-flex items-center" aria-label="Apex Packaging home">
          <img
            src="/images/brand/selected/apex-packaging-logo-footer.png"
            alt="Apex Packaging"
            width="420"
            height="155"
            class="h-14 w-auto md:h-16"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-white/65">
          Premium custom packaging solutions designed to protect, impress, and inspire your brand.
        </p>
        <div class="mt-6 flex gap-3">
          {socialLinks.map((item) => (
            <a href="/contact" class="grid h-10 w-10 place-items-center overflow-hidden rounded-md border border-white/15 bg-white/5 transition hover:border-[#d8ad3d]" aria-label={item.label}>
              <img src={item.image} alt="" width="96" height="96" loading="lazy" decoding="async" class="h-full w-full object-cover" />
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        {footerGroups.map((group) => (
          <div>
            <h2 class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#e1b84d]">{group.title}</h2>
            <ul class="mt-5 space-y-3 text-sm text-white/65">
              {group.links.map(([label, href]) => (
                <li><a href={href} class="transition hover:text-white">{label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div>
        <h2 class="text-xs font-extrabold uppercase tracking-[0.14em] text-[#e1b84d]">Contact Us</h2>
        <ul class="mt-5 space-y-5 text-sm text-white/72">
          <li class="flex gap-3">
            <span class="text-[#e1b84d]" aria-hidden="true">☎</span>
            <a href={phoneHref} class="font-bold text-white transition hover:text-[#e1b84d]">{phoneDisplay}</a>
          </li>
          <li class="flex min-w-0 gap-3">
            <span class="text-[#e1b84d]" aria-hidden="true">✉</span>
            <a href={`mailto:${siteConfig.email}`} class="min-w-0 break-all transition hover:text-[#e1b84d]">{siteConfig.email}</a>
          </li>
          <li class="flex gap-3">
            <span class="text-[#e1b84d]" aria-hidden="true">⌖</span>
            <span>{siteConfig.formattedAddress}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container max-w-wide flex flex-col gap-4 py-5 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <span>© {new Date().getFullYear()} Apex Packaging Solutions. All rights reserved.</span>
      <div class="flex flex-wrap gap-5">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/terms-and-conditions" class="hover:text-white">Terms</a>
        <a href="/refund-and-return-policy" class="hover:text-white">Returns</a>
        <a href="/sitemap-index.xml" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
