---
import { siteConfig } from '../../site.config';

const phoneDisplay = siteConfig.phoneDisplay ?? siteConfig.phone;
const phoneHref = siteConfig.phoneHref ?? `tel:${siteConfig.phone}`;

const infoLinks = [
  ['Privacy Policy', '/privacy'],
  ['Terms and Conditions', '/terms-and-conditions'],
  ['Return & Refund Policy', '/refund-and-return-policy'],
  ['About Us', '/about'],
  ['Contact Us', '/contact'],
  ['Sitemap', '/sitemap-index.xml'],
  ['Portfolio', '/services']
];

const productLinks = [
  ['Soap Boxes', '/services/mailer-boxes'],
  ['Pillow Boxes', '/services/mailer-boxes'],
  ['Rigid Boxes', '/services/mailer-boxes'],
  ['Kraft Boxes', '/services/corrugated-boxes'],
  ['Mylar Bags', '/services/polybags'],
  ['Gable Boxes', '/services/mailer-boxes']
];

const socialLinks = [
  { label: 'LinkedIn', href: '/contact', image: '/images/footer-icons/social/linkedin.png' },
  { label: 'YouTube', href: '/contact', image: '/images/footer-icons/social/youtube.png' },
  { label: 'Instagram', href: '/contact', image: '/images/footer-icons/social/instagram.png' }
];

const paymentMarks = [
  { label: 'PayPal', image: '/images/footer-icons/payments/paypal.png', width: 230, height: 56 },
  { label: 'Visa', image: '/images/footer-icons/payments/visa.png', width: 179, height: 58 },
  { label: 'Mastercard', image: '/images/footer-icons/payments/mastercard.png', width: 104, height: 62 },
  { label: 'American Express', image: '/images/footer-icons/payments/amex.png', width: 72, height: 72 }
];
---
<footer class="bg-neutral-100 text-neutral-900">
  <div class="grid lg:grid-cols-[minmax(320px,0.8fr)_minmax(640px,1.55fr)]">
    <section class="bg-neutral-800 px-4 py-10 text-neutral-50 md:px-12 lg:px-16">
      <a href="/" class="inline-flex items-center" aria-label="Apex Packaging home">
        <img
          src="/images/brand/selected/apex-packaging-logo-footer.png"
          alt="Apex Packaging"
          width="420"
          height="155"
          class="h-12 w-auto md:h-16"
          loading="lazy"
          decoding="async"
        />
      </a>

      <p class="mt-7 max-w-md font-display text-xl font-extrabold leading-snug text-neutral-200 md:mt-10 md:text-2xl">
        We collaborate with people and brands.
      </p>
      <p class="mt-4 text-base text-neutral-300 md:mt-8 md:text-lg">
        Lets build something great together.
      </p>

      <form class="mt-8 max-w-md md:mt-14">
        <label for="footer-email" class="mb-3 block text-base font-medium text-neutral-300 md:text-lg">
          Sign up for exclusive offers and updates!
        </label>
        <div class="grid gap-2 sm:flex">
          <input
            id="footer-email"
            class="h-12 min-w-0 flex-1 rounded-md border border-neutral-500 bg-neutral-50 px-4 text-neutral-900 placeholder:text-neutral-500 sm:rounded-r-none"
            placeholder="Your Email Address..."
            type="email"
          />
          <button class="h-12 rounded-md bg-accent px-5 font-bold text-neutral-900 hover:bg-warning sm:rounded-l-none" type="submit">
            Submit
          </button>
        </div>
      </form>
    </section>

    <section class="px-4 py-10 md:px-12 lg:px-16">
      <div class="grid gap-8 md:grid-cols-[0.9fr_1fr_1.35fr] md:gap-10">
        <div>
          <h2 class="mb-4 font-display text-base font-extrabold uppercase text-neutral-800 md:mb-6 md:text-lg">Information</h2>
          <ul class="grid grid-cols-2 gap-2 text-sm md:block md:space-y-3.5 md:text-base">
            {infoLinks.map(([label, href]) => (
              <li><a href={href} class="flex min-h-11 items-center rounded-md bg-neutral-50 px-3 transition-colors hover:text-accent md:min-h-0 md:bg-transparent md:px-0">{label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="mb-4 font-display text-base font-extrabold uppercase text-neutral-800 md:mb-6 md:text-lg">Packaging Products</h2>
          <ul class="grid grid-cols-2 gap-2 text-sm md:block md:space-y-3.5 md:text-base">
            {productLinks.map(([label, href]) => (
              <li><a href={href} class="flex min-h-11 items-center rounded-md bg-neutral-50 px-3 transition-colors hover:text-accent md:min-h-0 md:bg-transparent md:px-0">{label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="mb-6 font-display text-lg font-extrabold uppercase text-neutral-800">Contact Us</h2>
          <ul class="space-y-4 text-sm md:space-y-5 md:text-base">
            <li class="flex gap-4">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent font-bold text-neutral-900">E</span>
              <a href={`mailto:${siteConfig.email}`} class="min-w-0 break-all pt-1 hover:text-accent">{siteConfig.email}</a>
            </li>
            <li class="flex gap-4">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent font-bold text-neutral-900">P</span>
              <a href={phoneHref} class="pt-1 font-semibold hover:text-accent">{phoneDisplay}</a>
            </li>
            <li class="flex gap-4">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent font-bold text-neutral-900">L</span>
              <span class="pt-1 font-semibold">{siteConfig.formattedAddress}</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-8 grid gap-5 border-t border-neutral-200 pt-6 lg:grid-cols-[1fr_1.3fr] lg:items-center">
        <div class="flex flex-wrap items-center justify-center gap-3 text-center sm:justify-start md:gap-4">
          <span class="w-full font-display text-lg font-extrabold sm:w-auto sm:text-base md:text-lg">Follow Us:</span>
          {socialLinks.map((item) => (
            <a href={item.href} class="grid h-12 w-12 shrink-0 place-items-center overflow-hidden rounded-md bg-neutral-900 shadow-sm ring-1 ring-neutral-800/10 transition-opacity hover:opacity-85 md:h-11 md:w-11" aria-label={item.label}>
              <img src={item.image} alt="" width="96" height="96" loading="lazy" decoding="async" class="h-full w-full object-cover" />
            </a>
          ))}
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <span class="font-display font-extrabold">SSL 100% Secure Transactions:</span>
          <div class="flex flex-wrap items-center gap-2">
            {paymentMarks.map((item) => (
              <span class="grid h-11 w-24 place-items-center overflow-hidden rounded bg-white px-2 shadow-sm ring-1 ring-neutral-200" aria-label={item.label}>
                <img src={item.image} alt="" width={item.width} height={item.height} loading="lazy" decoding="async" class="h-auto max-h-9 max-w-full object-contain" />
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="border-t border-neutral-200 bg-neutral-50">
    <div class="container max-w-wide flex justify-center py-4 text-sm text-neutral-700 md:justify-end md:py-3">
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-accent">Privacy</a>
        <a href="/terms-and-conditions" class="hover:text-accent">Terms</a>
        <a href="/sitemap-index.xml" class="hover:text-accent">Sitemap</a>
        <a href="/contact" class="hover:text-accent">Get Quote</a>
      </div>
    </div>
  </section>
</footer>
