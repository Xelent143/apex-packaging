---
import { siteConfig } from '../../site.config';
const pathname = Astro.url.pathname;
const phoneDigits = siteConfig.phone.replace(/\D/g, '');
const hasPhone = phoneDigits.length >= 10 && !/^1?0+$/.test(phoneDigits);
const displayPhone = phoneDigits.length === 11 && phoneDigits.startsWith('1')
  ? `(${phoneDigits.slice(1, 4)}) ${phoneDigits.slice(4, 7)}-${phoneDigits.slice(7)}`
  : siteConfig.phone;
const whatsappHref = hasPhone ? `https://wa.me/${phoneDigits}` : '';
const packagingNav = [
  { label: 'Home', href: '/' },
  { label: 'Boxes by Industry', href: '/industries' },
  { label: 'Boxes By Material', href: '/services' },
  { label: 'Boxes By Style', href: '/services/corrugated-boxes' },
  { label: 'Blog', href: '/blog' },
  { label: 'Case Studies', href: '/design-support' },
  { label: 'Reviews', href: '/about' },
  { label: 'Portfolio', href: '/services' }
];
---
<header class="sticky top-0 z-30 bg-neutral-50 shadow-sm">
  <div class="container max-w-wide flex items-center justify-between gap-4 py-2 lg:py-2.5">
    <a href="/" class="flex shrink-0 items-center" aria-label="Apex Packaging home">
      <img
        src="/images/brand/selected/apex-packaging-logo-header.png"
        alt="Apex Packaging"
        width="420"
        height="155"
        class="h-9 w-auto md:h-10 lg:h-11"
        loading="eager"
        decoding="async"
      />
    </a>
    <div class="hidden items-center gap-4 lg:flex">
      {hasPhone && (
        <>
          <a href={`tel:${siteConfig.phone}`} class="group inline-flex items-center gap-2.5 text-neutral-900">
            <span class="grid h-10 w-10 place-items-center rounded-lg border border-[#c8d9dc] bg-[#edf4f5] text-[#1f6672] shadow-sm transition-transform duration-150 group-hover:-translate-y-0.5" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.11 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.78a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.3-1.23a2 2 0 0 1 2.11-.45c.89.31 1.82.53 2.78.66A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </span>
            <span class="font-display text-base font-extrabold tracking-tight xl:text-lg">{displayPhone}</span>
          </a>

          <span class="h-7 w-px bg-neutral-200" aria-hidden="true"></span>
        </>
      )}

      <a href={`mailto:${siteConfig.email}`} class="group inline-flex min-w-0 items-center gap-2.5 text-neutral-900">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg border border-[#c8d9dc] bg-[#edf4f5] text-[#1f6672] shadow-sm transition-transform duration-150 group-hover:-translate-y-0.5" aria-hidden="true">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2"></rect>
            <path d="m3 7 9 6 9-6"></path>
          </svg>
        </span>
        <span class="max-w-[260px] truncate font-display text-base font-extrabold tracking-tight xl:max-w-[360px] xl:text-lg 2xl:max-w-none">{siteConfig.email}</span>
      </a>

      {hasPhone && (
        <a href={whatsappHref} class="group grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-[#22c55e] text-white shadow-[0_10px_22px_rgba(34,197,94,0.18)] ring-1 ring-[#16a34a]/15 transition duration-150 hover:-translate-y-0.5 hover:bg-[#16a34a]" aria-label="Chat with Apex Packaging on WhatsApp">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2.75A9.15 9.15 0 0 0 4.2 16.62L3 21.25l4.73-1.18A9.15 9.15 0 1 0 12.04 2.75Zm0 1.72a7.43 7.43 0 0 1 6.32 11.35 7.52 7.52 0 0 1-8.9 2.73l-.33-.15-2.86.72.73-2.78-.17-.34a7.43 7.43 0 0 1 5.21-11.53Zm-3.22 3.92c-.17 0-.45.06-.68.33-.24.26-.9.87-.9 2.13 0 1.25.92 2.47 1.05 2.64.13.17 1.8 2.86 4.39 3.89 2.18.86 2.62.69 3.09.65.47-.04 1.52-.62 1.73-1.22.22-.6.22-1.11.15-1.22-.06-.11-.23-.17-.49-.3-.26-.13-1.52-.75-1.76-.84-.24-.09-.41-.13-.58.13-.17.26-.66.84-.81 1.01-.15.17-.3.2-.56.07-.26-.13-1.09-.4-2.08-1.28-.77-.68-1.28-1.52-1.43-1.78-.15-.26-.02-.4.11-.53.12-.12.26-.3.39-.45.13-.15.17-.26.26-.43.09-.17.04-.32-.02-.45-.07-.13-.58-1.4-.8-1.91-.21-.51-.43-.44-.58-.44h-.49Z"></path>
          </svg>
        </a>
      )}

      <a href="/contact" class="inline-flex h-10 shrink-0 items-center rounded-md bg-error px-5 font-display text-base font-extrabold text-neutral-50 shadow-sm transition-colors hover:bg-error/90 xl:px-6 xl:text-lg">
        Get Quote
      </a>
    </div>
    <div class="flex items-center gap-2 lg:hidden">
      {hasPhone && (
        <a href={whatsappHref} class="grid h-10 w-10 place-items-center rounded-lg bg-[#22c55e] text-white shadow-sm ring-1 ring-[#16a34a]/15" aria-label="Chat with Apex Packaging on WhatsApp">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.04 2.75A9.15 9.15 0 0 0 4.2 16.62L3 21.25l4.73-1.18A9.15 9.15 0 1 0 12.04 2.75Zm0 1.72a7.43 7.43 0 0 1 6.32 11.35 7.52 7.52 0 0 1-8.9 2.73l-.33-.15-2.86.72.73-2.78-.17-.34a7.43 7.43 0 0 1 5.21-11.53Zm-3.22 3.92c-.17 0-.45.06-.68.33-.24.26-.9.87-.9 2.13 0 1.25.92 2.47 1.05 2.64.13.17 1.8 2.86 4.39 3.89 2.18.86 2.62.69 3.09.65.47-.04 1.52-.62 1.73-1.22.22-.6.22-1.11.15-1.22-.06-.11-.23-.17-.49-.3-.26-.13-1.52-.75-1.76-.84-.24-.09-.41-.13-.58.13-.17.26-.66.84-.81 1.01-.15.17-.3.2-.56.07-.26-.13-1.09-.4-2.08-1.28-.77-.68-1.28-1.52-1.43-1.78-.15-.26-.02-.4.11-.53.12-.12.26-.3.39-.45.13-.15.17-.26.26-.43.09-.17.04-.32-.02-.45-.07-.13-.58-1.4-.8-1.91-.21-.51-.43-.44-.58-.44h-.49Z"></path>
          </svg>
        </a>
      )}
      <a href="/contact" class="inline-flex h-10 items-center rounded-md bg-error px-4 text-sm font-bold text-neutral-50">
        Quote
      </a>
    </div>
  </div>
  <div class="bg-neutral-800 text-neutral-50">
    <div class="container max-w-wide flex items-center justify-between gap-6 overflow-x-auto">
      <nav aria-label="Primary" class="flex min-w-max items-center text-sm font-bold">
        {packagingNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-5 py-4 transition-colors hover:bg-accent',
              item.label === 'Portfolio' ? 'bg-accent text-neutral-900' : '',
              pathname === item.href && item.href !== '/' ? 'bg-neutral-900' : ''
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <a href="/services" class="hidden shrink-0 items-center px-4 py-3 text-2xl font-bold hover:text-accent md:inline-flex" aria-label="Search packaging products">
        ⌕
      </a>
    </div>
  </div>
</header>
