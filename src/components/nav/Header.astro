---
import { siteConfig } from '../../site.config';
import { industryBoxes } from '../../data/industryBoxes';
const pathname = Astro.url.pathname;
const phoneDigits = siteConfig.phone.replace(/\D/g, '');
const hasPhone = phoneDigits.length >= 10 && !/^1?0+$/.test(phoneDigits);
const displayPhone = siteConfig.phoneDisplay ?? (phoneDigits.length === 11 && phoneDigits.startsWith('1')
  ? `(${phoneDigits.slice(1, 4)}) ${phoneDigits.slice(4, 7)}-${phoneDigits.slice(7)}`
  : siteConfig.phone);
const phoneHref = siteConfig.phoneHref ?? `tel:${siteConfig.phone}`;
const materialNav = [
  { label: 'Cardboard Boxes', href: '/services/corrugated-boxes', image: '/images/home/categories/custom-tuck-boxes.webp' },
  { label: 'Kraft Boxes', href: '/industries/retail-boxes', image: '/images/apex-update/materials/kraft-boxes.webp' },
  { label: 'Rigid Boxes', href: '/industries/gift-boxes', image: '/images/apex-update/materials/rigid-boxes.webp' },
  { label: 'Corrugated Boxes', href: '/services/corrugated-boxes', image: '/images/apex-update/materials/corrugated-boxes.webp' }
];
const styleNav = [
  { label: 'Custom Tuck Boxes', href: '/industries/product-boxes', image: '/images/home/categories/custom-tuck-boxes.webp' },
  { label: 'Custom Display Boxes', href: '/industries/retail-boxes', image: '/images/home/categories/display-boxes.webp' },
  { label: 'Custom Mailer Boxes', href: '/services/mailer-boxes', image: '/images/home/mailer-boxes-branded.webp' },
  { label: 'Custom Pillow Boxes', href: '/industries/gift-boxes', image: '/images/home/categories/pillow-boxes.webp' },
  { label: 'Custom Bakery Boxes', href: '/industries/bakery-boxes', image: '/images/home/categories/bakery-boxes.webp' },
  { label: 'CBD Boxes', href: '/services/cbd-boxes', image: '/images/apex-update/styles/cbd-boxes-premium.png' }
];
const simpleNav = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' }
];
const isIndustryActive = pathname === '/industries' || pathname.startsWith('/industries/');
const isServicesActive = pathname === '/services' || pathname.startsWith('/services/');
---
<header class="bg-white shadow-sm lg:sticky lg:top-0 lg:z-30">
  <div class="hidden bg-neutral-950 text-neutral-50 lg:block">
    <div class="mx-auto grid min-h-8 w-full grid-cols-[auto_1fr_auto] items-center gap-6 px-6 text-xs font-black tracking-wide md:px-8">
      <div class="flex items-center gap-3 text-accent-soft">
        <span class="grid h-5 w-5 place-items-center rounded border border-accent-soft/45" aria-hidden="true">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-9-5-9 5 9 5 9-5Z"></path>
            <path d="M3 8v8l9 5 9-5V8"></path>
            <path d="M12 13v8"></path>
          </svg>
        </span>
        <span>Order with confidence.</span>
        <span class="ml-4 h-5 w-px bg-accent-soft/45" aria-hidden="true"></span>
      </div>
      <div class="flex items-center justify-center gap-2 text-neutral-200">
        <span class="text-accent-soft" aria-hidden="true">↯</span>
        <span>Fast turnaround. Premium quality. Delivered in as fast as <strong class="text-accent-soft">7 days.</strong></span>
      </div>
      <div class="flex items-center justify-end gap-3 text-accent-soft">
        <span class="text-accent-soft" aria-hidden="true">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.93a1 1 0 0 1-.67 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.2 1.2 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1v7Z"></path>
          </svg>
        </span>
        <span>Secure packaging. Protected delivery.</span>
      </div>
    </div>
  </div>

  <div class="bg-neutral-950 px-4 py-3 text-neutral-50 lg:hidden">
    <div class="mx-auto grid max-w-md grid-cols-[1fr_auto_1.12fr_auto_1fr] items-center gap-3 text-[0.68rem] font-extrabold leading-tight">
      <div class="flex items-center gap-2">
        <span class="grid h-8 w-8 shrink-0 place-items-center text-accent-soft" aria-hidden="true">
          <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-9-5-9 5 9 5 9-5Z"></path>
            <path d="M3 8v8l9 5 9-5V8"></path>
            <path d="M12 13v8"></path>
          </svg>
        </span>
        <span><strong class="text-accent-soft">Order with</strong><br />confidence.</span>
      </div>
      <span class="h-12 w-px bg-white/30" aria-hidden="true"></span>
      <div class="flex items-center gap-2">
        <span class="text-2xl leading-none text-accent-soft" aria-hidden="true">↯</span>
        <span>Fast turnaround.<br />Premium quality.<br />Delivered in as fast as <strong class="text-accent-soft">7 days.</strong></span>
      </div>
      <span class="h-12 w-px bg-white/30" aria-hidden="true"></span>
      <div class="flex items-center gap-2">
        <span class="grid h-8 w-8 shrink-0 place-items-center text-accent-soft" aria-hidden="true">
          <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.93a1 1 0 0 1-.67 0C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.2 1.2 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1v7Z"></path>
            <path d="m9.5 12.5 1.7 1.7 3.6-4.1"></path>
          </svg>
        </span>
        <span><strong class="text-accent-soft">Secure</strong><br />packaging.<br />Protected delivery.</span>
      </div>
    </div>
  </div>

  <div class="mx-auto hidden w-full items-center justify-between gap-3 px-4 py-3 md:px-6 lg:grid lg:min-h-[5.75rem] lg:grid-cols-[230px_minmax(18rem,1fr)_auto] lg:gap-7 lg:px-8 lg:py-4 xl:grid-cols-[250px_minmax(22rem,1fr)_auto]">
    <a href="/" class="flex shrink-0 items-center" aria-label="Apex Packaging home">
      <img
        src="/images/apex-update/brand/final-logo.webp"
        srcset="/images/apex-update/brand/final-logo-330.webp 330w, /images/apex-update/brand/final-logo-660.webp 660w, /images/apex-update/brand/final-logo-1032.webp 1032w"
        sizes="(max-width: 1023px) 55vw, 250px"
        alt="Apex Packaging"
        width="2064"
        height="762"
        class="h-10 w-auto md:h-12 lg:h-16 xl:h-16"
        loading="eager"
        decoding="async"
      />
    </a>
    <form action="/services" class="hidden h-11 w-full max-w-[24rem] min-w-0 justify-self-start rounded-full border border-neutral-200 bg-white pl-5 pr-2 shadow-[0_8px_22px_rgba(15,13,10,0.07)] ring-1 ring-neutral-100 lg:flex lg:items-center xl:max-w-[26rem]" role="search">
      <input
        class="min-w-0 flex-1 bg-transparent text-sm font-semibold text-neutral-800 outline-none placeholder:text-neutral-400"
        name="q"
        placeholder="Search packaging..."
        aria-label="Search packaging"
      />
      <button class="grid h-8 w-8 shrink-0 place-items-center rounded-full text-accent transition hover:bg-[#fff4cf]" type="submit" aria-label="Search">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
    </form>
    <div class="hidden items-center justify-end gap-4 lg:flex">
      {hasPhone && (
        <>
          <div class="group inline-flex items-center gap-3 text-neutral-900">
            <span class="grid h-10 w-10 place-items-center rounded-full border-2 border-accent text-accent transition-transform duration-150 group-hover:-translate-y-0.5" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.11 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.78a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.3-1.23a2 2 0 0 1 2.11-.45c.89.31 1.82.53 2.78.66A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </span>
            <span>
              <span class="block whitespace-nowrap text-xs font-bold text-neutral-900">Speak with a Packaging Expert</span>
              <a href={phoneHref} class="block whitespace-nowrap font-display text-lg font-extrabold tracking-tight text-neutral-950 transition-colors hover:text-accent">{displayPhone}</a>
              <a href={`mailto:${siteConfig.email}`} class="block whitespace-nowrap text-xs font-bold text-neutral-700 transition-colors hover:text-accent">{siteConfig.email}</a>
            </span>
          </div>
          <span class="h-9 w-px bg-neutral-300" aria-hidden="true"></span>
        </>
      )}
      <a href="/contact" class="inline-flex h-11 shrink-0 items-center gap-3 rounded-md bg-accent px-5 font-display text-sm font-extrabold uppercase tracking-wide text-white shadow-[0_10px_18px_rgba(214,158,0,0.18)] transition-colors hover:bg-warning xl:px-6">
        Request a Quote
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="bg-white px-4 py-4 lg:hidden">
    <div class="mx-auto max-w-md space-y-4">
      <div class="grid grid-cols-[3.25rem_1fr_3.25rem_3.25rem] items-center gap-3">
        <button type="button" class="grid h-12 w-12 place-items-center text-neutral-950" aria-label="Open menu">
          <span class="space-y-1.5" aria-hidden="true">
            <span class="block h-0.5 w-8 rounded-full bg-current"></span>
            <span class="block h-0.5 w-8 rounded-full bg-current"></span>
            <span class="block h-0.5 w-8 rounded-full bg-current"></span>
          </span>
        </button>
        <a href="/" class="flex justify-center" aria-label="Apex Packaging home">
          <img
            src="/images/apex-update/brand/final-logo.webp"
            srcset="/images/apex-update/brand/final-logo-330.webp 330w, /images/apex-update/brand/final-logo-660.webp 660w, /images/apex-update/brand/final-logo-1032.webp 1032w"
            sizes="55vw"
            alt="Apex Packaging"
            width="2064"
            height="762"
            class="h-[4.6rem] w-auto max-w-full object-contain"
            loading="eager"
            decoding="async"
          />
        </a>
        <a href="/services" class="grid h-12 w-12 place-items-center rounded-full border border-neutral-300 bg-white text-neutral-950 shadow-sm" aria-label="Search packaging">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </a>
        {hasPhone && (
          <a href={phoneHref} class="grid h-12 w-12 place-items-center rounded-full border border-accent/55 bg-white text-accent shadow-sm" aria-label={`Call Apex Packaging at ${displayPhone}`}>
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.35" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.11 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.78a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.3-1.23a2 2 0 0 1 2.11-.45c.89.31 1.82.53 2.78.66A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </a>
        )}
      </div>

      <form action="/services" class="flex h-[4.15rem] items-center rounded-full border border-neutral-200 bg-white pl-4 pr-1.5 shadow-[0_8px_20px_rgba(15,13,10,0.14)] ring-1 ring-neutral-100" role="search">
        <svg class="h-7 w-7 shrink-0 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <input
          class="min-w-0 flex-1 bg-transparent px-4 text-base font-medium text-neutral-800 outline-none placeholder:text-neutral-400"
          name="q"
          placeholder="Search packaging..."
          aria-label="Search packaging"
        />
        <button class="grid h-14 w-14 shrink-0 place-items-center rounded-full bg-gradient-to-b from-[#efbd39] to-[#c98400] text-white shadow-[0_8px_16px_rgba(201,132,0,0.28)]" type="submit" aria-label="Search">
          <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.55" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </form>

      <a href="/contact" class="flex h-[4.45rem] items-center justify-center gap-4 rounded-md bg-gradient-to-b from-[#efbd39] to-[#c98400] font-display text-[1.05rem] font-extrabold uppercase tracking-[0.09em] text-white shadow-[0_10px_18px_rgba(201,132,0,0.2)]">
        Request a Quote
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m13 5 7 7-7 7"></path>
        </svg>
      </a>

      {hasPhone && (
        <a href={phoneHref} class="grid min-h-[4.75rem] grid-cols-[4.4rem_1px_1fr] items-center rounded-xl border border-neutral-200 bg-white shadow-[0_6px_16px_rgba(15,13,10,0.08)]">
          <span class="grid place-items-center">
            <span class="grid h-14 w-14 place-items-center rounded-full border-2 border-accent text-accent" aria-hidden="true">
              <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.11 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.89.66 2.78a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.3-1.23a2 2 0 0 1 2.11-.45c.89.31 1.82.53 2.78.66A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </span>
          </span>
          <span class="h-12 bg-neutral-200" aria-hidden="true"></span>
          <span class="px-5">
            <span class="block text-base font-medium text-neutral-950">Speak with a Packaging Expert</span>
            <span class="block font-display text-[1.55rem] font-extrabold leading-tight tracking-wide text-neutral-950">{displayPhone}</span>
          </span>
        </a>
      )}

      <nav aria-label="Primary mobile" class="flex gap-3 overflow-x-auto pb-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <a href="/industries" class="grid min-h-[6.8rem] min-w-[5.9rem] place-items-center rounded-xl border border-neutral-200 bg-white px-2 py-3 text-center text-sm font-semibold leading-tight text-neutral-950 shadow-[0_7px_18px_rgba(15,13,10,0.08)]">
          <svg class="h-9 w-9 text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3 21h18v-2h-2V8.4l-5-2.5V19h-2V3L5 6.5V19H3v2Zm4-9h2v2H7v-2Zm0 4h2v2H7v-2Zm8-3h2v2h-2v-2Zm0 4h2v2h-2v-2Z"></path>
          </svg>
          <span>Industries</span>
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <a href="/services/mailer-boxes" class="grid min-h-[6.8rem] min-w-[5.9rem] place-items-center rounded-xl border border-neutral-200 bg-white px-2 py-3 text-center text-sm font-semibold leading-tight text-neutral-950 shadow-[0_7px_18px_rgba(15,13,10,0.08)]">
          <svg class="h-9 w-9 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m21 8-9-5-9 5 9 5 9-5Z"></path>
            <path d="M3 8v8l9 5 9-5V8"></path>
            <path d="M12 13v8"></path>
          </svg>
          <span>Product<br />Styles</span>
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <a href="/services/cbd-boxes" class="grid min-h-[6.8rem] min-w-[5.9rem] place-items-center rounded-xl border border-neutral-200 bg-white px-2 py-3 text-center text-sm font-semibold leading-tight text-neutral-950 shadow-[0_7px_18px_rgba(15,13,10,0.08)]">
          <span class="grid h-10 w-10 place-items-center rounded-lg bg-[#fff4cf] text-accent ring-1 ring-[#ead58d]" aria-hidden="true">
            <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="m21 8-9-5-9 5 9 5 9-5Z"></path>
              <path d="M3 8v8l9 5 9-5V8"></path>
              <path d="M12 13v8"></path>
              <path d="m8.5 7 7 4"></path>
            </svg>
          </span>
          <span>CBD<br />Boxes</span>
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <a href="/services" class="grid min-h-[6.8rem] min-w-[5.9rem] place-items-center rounded-xl border border-neutral-200 bg-white px-2 py-3 text-center text-sm font-semibold leading-tight text-neutral-950 shadow-[0_7px_18px_rgba(15,13,10,0.08)]">
          <svg class="h-9 w-9 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m3 7 9 5 9-5"></path>
            <path d="M12 12v9"></path>
            <path d="M4 10v7l8 4 8-4v-7"></path>
            <path d="m8 4 4-2 4 2"></path>
          </svg>
          <span>Custom<br />Boxes</span>
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
        <a href="/blog" class="grid min-h-[6.8rem] min-w-[5.9rem] place-items-center rounded-xl border border-neutral-200 bg-white px-2 py-3 text-center text-sm font-semibold leading-tight text-neutral-950 shadow-[0_7px_18px_rgba(15,13,10,0.08)]">
          <svg class="h-9 w-9 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"></circle>
            <path d="m12 6.8 1.45 3.05 3.35.45-2.45 2.35.6 3.3L12 14.35l-2.95 1.6.6-3.3L7.2 10.3l3.35-.45L12 6.8Z" fill="currentColor" stroke="none"></path>
          </svg>
          <span>Success<br />Stories</span>
          <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </a>
      </nav>
    </div>
  </div>

  <div class="hidden border-y border-neutral-200 bg-white lg:block">
    <div class="relative mx-auto hidden w-full items-center justify-between gap-6 px-8 lg:flex">
      <nav aria-label="Primary" class="flex min-w-max items-center text-sm font-black text-neutral-800">
        {simpleNav.slice(0, 1).map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-5 py-3 transition-colors hover:text-accent',
              pathname === item.href ? 'text-accent' : ''
            ]}
          >
            {item.label}
          </a>
        ))}

        <div class="group">
          <a
            href="/industries"
            data-industry-trigger
            class:list={[
              'inline-flex items-center gap-1 px-5 py-3 transition-colors hover:text-accent',
              isIndustryActive ? 'text-accent' : ''
            ]}
          >
            Boxes by Industry <span aria-hidden="true">⌄</span>
          </a>
          <div data-industry-mega-menu class="invisible absolute left-10 right-10 top-full z-50 max-h-[calc(100vh-8rem)] overflow-y-auto rounded-b-md border border-neutral-200 bg-white text-neutral-900 opacity-0 shadow-popover transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
            <div class="border-b border-neutral-200 bg-neutral-50 px-7 py-5">
              <p class="text-xs font-black uppercase tracking-[0.16em] text-accent">Browse packaging categories</p>
              <div class="mt-1 flex items-end justify-between gap-6">
                <h2 class="font-display text-2xl font-extrabold leading-tight text-neutral-900">Boxes by industry</h2>
                <a href="/industries" class="shrink-0 text-sm font-black uppercase tracking-wide text-neutral-700 hover:text-accent">View all</a>
              </div>
            </div>
            <div class="px-7 py-6">
              <div class="grid gap-x-5 gap-y-3 lg:grid-cols-4 xl:grid-cols-5">
                {industryBoxes.map((box) => (
                  <a
                    href={`/industries/${box.slug}`}
                    class:list={[
                      'group/item grid min-h-[52px] grid-cols-[34px_1fr] items-center gap-3 rounded-md border border-transparent px-3 py-2 transition hover:border-[#ead58d] hover:bg-[#fff9e8]',
                      pathname === `/industries/${box.slug}` ? 'bg-[#fff7dd]' : ''
                    ]}
                  >
                    <span class="grid h-[34px] w-[34px] place-items-center overflow-hidden rounded-md bg-[#fff4cf] ring-1 ring-[#ead58d]/60 transition group-hover/item:-translate-y-0.5 group-hover/item:ring-accent" aria-hidden="true">
                      <img
                        src={box.icon}
                        alt=""
                        width="160"
                        height="160"
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover"
                      />
                    </span>
                    <span class="font-display text-[0.92rem] font-extrabold leading-snug text-neutral-800">{box.shortLabel ?? box.label}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="group">
          <a
            href="/services"
            class:list={[
              'inline-flex items-center gap-1 px-5 py-3 transition-colors hover:text-accent',
              isServicesActive ? 'text-accent' : ''
            ]}
          >
            Boxes By Material <span aria-hidden="true">⌄</span>
          </a>
          <div class="invisible absolute left-10 right-10 top-full z-50 rounded-b-md border border-neutral-200 bg-white text-neutral-900 opacity-0 shadow-popover transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
            <div class="grid gap-4 p-6 md:grid-cols-4">
              {materialNav.map((item) => (
                <a href={item.href} class="group/item overflow-hidden rounded-md border border-neutral-200 bg-neutral-50 transition hover:-translate-y-1 hover:border-accent hover:shadow-card">
                  <img src={item.image} alt={`${item.label} packaging`} width="724" height="543" loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover transition duration-200 group-hover/item:scale-[1.03]" />
                  <span class="block px-4 py-3 font-display text-base font-extrabold text-neutral-900">{item.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="group">
          <a
            href="/services/mailer-boxes"
            class="inline-flex items-center gap-1 px-5 py-3 transition-colors hover:text-accent"
          >
            Boxes By Style <span aria-hidden="true">⌄</span>
          </a>
          <div class="invisible absolute left-10 right-10 top-full z-50 rounded-b-md border border-neutral-200 bg-white text-neutral-900 opacity-0 shadow-popover transition duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
            <div class="grid gap-4 p-6 md:grid-cols-6">
              {styleNav.map((item) => (
                <a href={item.href} class="group/item overflow-hidden rounded-md border border-neutral-200 bg-neutral-50 transition hover:-translate-y-1 hover:border-accent hover:shadow-card">
                  <img src={item.image} alt={`${item.label} packaging`} width="724" height="543" loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover transition duration-200 group-hover/item:scale-[1.03]" />
                  <span class="block px-4 py-3 font-display text-base font-extrabold text-neutral-900">{item.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a
          href="/services/cbd-boxes"
          class:list={[
            'px-5 py-3 transition-colors hover:text-accent',
            pathname === '/services/cbd-boxes' ? 'text-accent' : ''
          ]}
        >
          CBD Boxes
        </a>

        {simpleNav.slice(1).map((item) => (
          <a
            href={item.href}
            class:list={[
              'px-5 py-3 transition-colors hover:text-accent',
              pathname === item.href && item.href !== '/' ? 'text-accent' : ''
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <div class="hidden shrink-0 items-center gap-2 border-l border-neutral-200 pl-5 text-xs font-black uppercase tracking-wide text-neutral-700 xl:flex">
        <span>Global Operations:</span>
        <span class="text-base" role="img" aria-label="United States">🇺🇸</span>
        <span class="text-base" role="img" aria-label="Canada">🇨🇦</span>
        <span class="text-base" role="img" aria-label="United Kingdom">🇬🇧</span>
        <span class="text-base" role="img" aria-label="Australia">🇦🇺</span>
        <span class="text-base" role="img" aria-label="Germany">🇩🇪</span>
      </div>
    </div>
  </div>
</header>
