---
const defaultWidgetUrl = 'https://embed.tawk.to/6a23dd698705f01c35097370/1jqe1hp6i';
const widgetUrl = import.meta.env.PUBLIC_TAWK_TO_WIDGET_URL?.trim() || defaultWidgetUrl;
const tawkWidgetUrl =
  widgetUrl && /^https:\/\/embed\.tawk\.to\/[A-Za-z0-9_-]+\/[A-Za-z0-9_-]+\/?$/.test(widgetUrl)
    ? widgetUrl
    : '';
---

{tawkWidgetUrl && (
  <>
    <button
      id="apex-chat-launcher"
      type="button"
      class="apex-chat-launcher"
      aria-label="Open live chat"
    >
      <span class="apex-chat-label">Chat</span>
    </button>
    <style>
      .apex-chat-launcher {
        position: fixed;
        right: 20px;
        bottom: 20px;
        right: calc(20px + env(safe-area-inset-right, 0px));
        bottom: calc(20px + env(safe-area-inset-bottom, 0px));
        z-index: 2147483000;
        display: inline-flex;
        min-width: 94px;
        height: 52px;
        align-items: center;
        justify-content: center;
        border: 1px solid rgb(255 255 255 / 0.16);
        border-radius: 999px;
        background: #080705;
        color: #fff;
        box-shadow: 0 18px 45px rgb(0 0 0 / 0.22);
        font: 900 15px/1 Arial, Helvetica, sans-serif;
        letter-spacing: 0;
        text-transform: uppercase;
        cursor: pointer;
        transition:
          background-color 160ms ease,
          box-shadow 160ms ease,
          transform 160ms ease;
      }

      .apex-chat-launcher:hover {
        background: #1b1711;
        box-shadow: 0 20px 50px rgb(0 0 0 / 0.28);
        transform: translateY(-1px);
      }

      .apex-chat-launcher:focus-visible {
        outline: 3px solid #b88712;
        outline-offset: 3px;
      }

      .apex-chat-launcher[aria-busy='true'] {
        cursor: wait;
        opacity: 0.88;
      }

      .apex-chat-launcher[hidden] {
        display: none !important;
      }

      @media (max-width: 767px) {
        .apex-chat-launcher {
          right: 16px;
          bottom: 24px;
          right: calc(16px + env(safe-area-inset-right, 0px));
          bottom: calc(24px + env(safe-area-inset-bottom, 0px));
          min-width: 92px;
          height: 52px;
          font-size: 14px;
        }
      }
    </style>
    <script is:inline define:vars={{ tawkWidgetUrl }}>
      window.Tawk_API = window.Tawk_API || {};

      (function () {
        var launcher = document.getElementById('apex-chat-launcher');
        var loaded = false;
        var opening = false;
        var openAttempts = 0;
        var openTimer = 0;
        var previousOnLoad = window.Tawk_API.onLoad;
        var previousOnChatMaximized = window.Tawk_API.onChatMaximized;

        function setLauncherLabel(label) {
          if (!launcher) return;
          var labelNode = launcher.querySelector('.apex-chat-label');
          if (labelNode) labelNode.textContent = label;
        }

        function hideLauncher() {
          if (launcher) launcher.setAttribute('hidden', '');
        }

        function openLoadedChat() {
          if (!window.Tawk_API || typeof window.Tawk_API.maximize !== 'function') return false;

          try {
            if (typeof window.Tawk_API.showWidget === 'function') {
              window.Tawk_API.showWidget();
            }
            window.Tawk_API.maximize();
            hideLauncher();
            return true;
          } catch (error) {
            return false;
          }
        }

        function stopOpenPolling() {
          if (openTimer) {
            window.clearInterval(openTimer);
            openTimer = 0;
          }
        }

        function resetLauncher() {
          opening = false;
          stopOpenPolling();
          if (launcher) launcher.removeAttribute('aria-busy');
          setLauncherLabel('Chat');
        }

        function waitForChatApi() {
          stopOpenPolling();
          openAttempts = 0;

          openTimer = window.setInterval(function () {
            openAttempts += 1;
            if (openLoadedChat()) {
              stopOpenPolling();
              return;
            }
            if (openAttempts >= 40) {
              resetLauncher();
            }
          }, 250);
        }

        window.Tawk_API.onLoad = function () {
          if (typeof previousOnLoad === 'function') previousOnLoad();
          if (opening) {
            window.setTimeout(function () {
              if (!openLoadedChat()) waitForChatApi();
            }, 250);
          }
        };

        window.Tawk_API.onChatMaximized = function () {
          if (typeof previousOnChatMaximized === 'function') previousOnChatMaximized();
          hideLauncher();
        };

        function loadChat() {
          if (loaded) {
            openLoadedChat();
            return;
          }

          loaded = true;
          window.Tawk_LoadStart = new Date();

          var script = document.createElement('script');
          var firstScript = document.getElementsByTagName('script')[0];

          script.async = true;
          script.src = tawkWidgetUrl;
          script.charset = 'UTF-8';
          script.onload = function () {
            if (opening) waitForChatApi();
          };
          script.onerror = function () {
            loaded = false;
            resetLauncher();
          };

          firstScript.parentNode.insertBefore(script, firstScript);
        }

        if (launcher) {
          launcher.addEventListener('click', function () {
            opening = true;
            launcher.setAttribute('aria-busy', 'true');
            setLauncherLabel('Opening');
            loadChat();
            waitForChatApi();
          });
        }
      })();
    </script>
  </>
)}
