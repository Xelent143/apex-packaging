---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import PaymentForm from '../components/sections/PaymentForm.astro';
import { buildBreadcrumbSchema } from '../lib/schema';

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Pay Invoice', url: '/pay' }
]);
---
<BaseLayout
  title="Pay Apex Packaging Invoice | Secure Stripe Checkout"
  description="Pay an approved Apex Packaging quote or invoice using secure Stripe-hosted checkout."
  schemaBlocks={[breadcrumb]}
  noindex
>
  <PageHeader
    eyebrow="Secure payment"
    heading="Pay an approved quote or invoice."
    lead="Review the policy links, confirm your agreement, and then continue to Stripe-hosted checkout. Card details are handled by Stripe and not stored on this website."
  />

  <section class="bg-neutral-50 py-12 md:py-24">
    <div class="container max-w-wide">
      <PaymentForm />
    </div>
  </section>
</BaseLayout>
