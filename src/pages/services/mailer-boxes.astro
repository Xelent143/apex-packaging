---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import RelatedContent from '../../components/sections/RelatedContent.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { buildBreadcrumbSchema, buildServiceSchema, buildFAQSchema } from '../../lib/schema';

const faqs = [
  { q: 'What is the minimum order on custom-printed mailers?', a: '250 units for flexo. 50 units for digital. Volume pricing kicks in at 1,000.' },
  { q: 'What artwork files do you need?', a: 'Vector logos (AI, EPS, or PDF). Brand colours as Pantone codes. Apex\'s design team can convert raster art to print-ready vector — included with order.' },
  { q: 'How does the price compare to overseas suppliers?', a: 'For runs under 5,000 units, Apex is typically cost-comparable or cheaper after freight and duty. Above 10,000 units, overseas can win on unit cost but loses 4–6 weeks of lead time and incurs higher tariff risk.' },
  { q: 'Can I print on the inside of the box?', a: 'Yes — one-colour or full-colour interior. Adds about 8–12% to per-unit cost depending on coverage.' }
];
const breadcrumb = buildBreadcrumbSchema([{name:'Home',url:'/'},{name:'Services',url:'/services'},{name:'Mailer Boxes',url:'/services/mailer-boxes'}]);
const service = buildServiceSchema({ name:'Custom mailer boxes Canada', description:'Custom-printed mailer boxes for Canadian e-commerce. Tuck-top, magnetic close, ZIP-tear. MOQ from 250.', url:'/services/mailer-boxes'});
---
<BaseLayout
  title="Custom Mailer Boxes Canada — Printed Shipping Boxes"
  description="Custom-printed mailer boxes manufactured in Canada. Tuck-top, magnetic close, ZIP-tear. MOQ from 250 units, full-colour exterior and interior print, 7–14 day lead time."
  schemaBlocks={[breadcrumb, service, buildFAQSchema(faqs)]}
>
  <PageHeader
    eyebrow="Service · Mailer Boxes"
    heading="Custom mailer boxes — branded outside, printed inside, shipped in 7–14 days."
    lead="For Canadian e-commerce and D2C brands that want a real unboxing without a 5,000-unit MOQ or a 6-week wait. Apex manufactures custom-printed mailer boxes domestically with MOQ from 250 units."
    imageSrc="/images/services/mailer-boxes-generated-banner.webp"
    imageAlt="Apex Packaging custom mailer box banner with headline, feature icons, and branded black, kraft, and white mailer boxes."
    imageIsFullBanner={true}
  />

  <section class="py-16 md:py-24">
    <div class="container max-w-default prose-apex">
      <h2>Structural options</h2>
      <ul>
        <li><strong>Tuck-top mailer</strong> — friction-tab closure, the standard e-commerce mailer.</li>
        <li><strong>Magnetic-close mailer</strong> — premium retail-feel, hidden magnet closure.</li>
        <li><strong>ZIP-tear opening</strong> — perforated pull-strip for unboxing experience.</li>
        <li><strong>Dispenser-style</strong> — open-flap design for repeat-access products.</li>
        <li><strong>Custom dieline</strong> — Apex's design team draws a structural dieline from product dimensions.</li>
      </ul>

      <h2>Print options</h2>
      <ul>
        <li><strong>Exterior full-colour print</strong> with one-pass digital or flexo. Spot colour matching to brand swatch.</li>
        <li><strong>Interior print</strong> — one colour or full-colour. Used for inside-lid messaging or pattern.</li>
        <li><strong>Spot UV, foil stamp, embossing</strong> available on litho-laminated stock.</li>
        <li><strong>Spot coatings</strong> — matte, soft-touch, gloss.</li>
      </ul>

      <h2>Material options</h2>
      <ul>
        <li>E-flute corrugated (standard for mailers) — light, printable, structurally rigid.</li>
        <li>B-flute (heavier feel, more protection).</li>
        <li>FSC-certified liner on request.</li>
        <li>30–100% recycled content available.</li>
      </ul>

      <h2>Sample process</h2>
      <ol>
        <li>Send brand assets (logo, brand colours, any reference photos).</li>
        <li>Apex returns a structural dieline and a 3D mockup in 48–72 hours.</li>
        <li>Approve digitally, or order a physical pre-production sample.</li>
        <li>On approval, full production runs 7–14 days.</li>
      </ol>
    </div>
  </section>

  <FAQAccordion faqs={faqs} />

  <RelatedContent items={[
    { title:'Corrugated Boxes', href:'/services/corrugated-boxes', description:'Standard and custom corrugated shipping boxes.' },
    { title:'Design Support', href:'/design-support', description:'Send a logo — get a dieline and 3D mockup in 48–72h.' },
    { title:'Sustainability', href:'/sustainability', description:'FSC, recycled, and compostable options.' }
  ]} />

  <CTABand
    heading="Send brand assets and dimensions."
    lead="A dieline and quote come back the same business day."
    primaryCta={{ label: 'Request a quote', href: '/contact' }}
  />
</BaseLayout>
