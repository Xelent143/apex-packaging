---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import RelatedContent from '../../components/sections/RelatedContent.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { buildBreadcrumbSchema, buildFAQSchema, buildServiceSchema } from '../../lib/schema';

const heroImage = '/images/services/cbd-boxes-premium-hero.png';
const packagingGallery = [
  {
    title: 'Tincture Cartons',
    brand: 'Viren Botanics',
    image: '/images/services/cbd-gallery/tincture-carton.webp',
    alt: 'Fictional Viren Botanics CBD tincture carton and amber bottle'
  },
  {
    title: 'Rigid Gift Boxes',
    brand: 'Aurelia Root',
    image: '/images/services/cbd-gallery/rigid-gift-box.webp',
    alt: 'Fictional Aurelia Root luxury CBD rigid gift box with inserts'
  },
  {
    title: 'Gummy Sleeve Boxes',
    brand: 'Moss & Moon',
    image: '/images/services/cbd-gallery/gummy-sleeve-box.webp',
    alt: 'Fictional Moss and Moon CBD gummy sleeve and drawer box'
  },
  {
    title: 'Kraft Topical Cartons',
    brand: 'Northwild Lab',
    image: '/images/services/cbd-gallery/kraft-topical-cartons.webp',
    alt: 'Fictional Northwild Lab sustainable kraft CBD topical cartons'
  },
  {
    title: 'Retail Display Trays',
    brand: 'Solace Current',
    image: '/images/services/cbd-gallery/retail-display-tray.webp',
    alt: 'Fictional Solace Current CBD cartons in a retail display tray'
  }
];
const faqs = [
  {
    q: 'Can Apex make CBD boxes with premium finishes?',
    a: 'Yes. Apex can quote soft-touch laminate, foil, embossing, spot UV, kraft stocks, rigid gift boxes, sleeves, display trays, and retail tuck cartons.'
  },
  {
    q: 'Can the dieline leave room for compliance copy?',
    a: 'Yes. The print layout can reserve panels for ingredients, warnings, dosage or use notes, batch codes, barcode zones, and other client-supplied regulatory content.'
  },
  {
    q: 'What CBD box styles are available?',
    a: 'Common styles include reverse tuck cartons, straight tuck cartons, sleeve boxes, rigid gift boxes, display trays, insert boxes, and mailer kits for ecommerce.'
  },
  {
    q: 'Can I order samples before full production?',
    a: 'Yes. Apex can prepare digital proofs and quote pre-production samples so fit, material, color, and finish choices are confirmed before the production run.'
  }
];

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: 'CBD Boxes', url: '/services/cbd-boxes' }
]);

const service = buildServiceSchema({
  name: 'Custom CBD boxes Canada',
  description: 'Premium custom CBD boxes for tinctures, jars, gummies, balms, retail sets, display trays, and ecommerce kits with custom print and finishes.',
  url: '/services/cbd-boxes'
});
---
<BaseLayout
  title="Custom CBD Boxes Canada | Premium CBD Packaging"
  description="Premium custom CBD boxes for tinctures, jars, gummies, balms, display trays, and retail sets. Apex supports custom dielines, samples, finishes, and production-ready packaging."
  image={heroImage}
  schemaBlocks={[breadcrumb, service, buildFAQSchema(faqs)]}
>
  <section class="relative isolate min-h-[44rem] overflow-hidden bg-[#efe7da] md:min-h-0">
    <img
      src={heroImage}
      alt="Premium CBD packaging boxes with black, gold, kraft, and white custom box styles"
      width="2048"
      height="768"
      class="absolute inset-0 h-full w-full object-cover object-[70%_center] opacity-45 md:static md:min-h-[39rem] md:opacity-100 md:object-[76%_center] lg:object-[72%_center]"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#f4eadc]/96 via-[#f4eadc]/92 to-[#f4eadc]/68 md:bg-gradient-to-r md:from-[#f4eadc] md:from-0% md:via-[#f4eadc]/95 md:via-45% md:to-[#f4eadc]/0 md:to-72%" aria-hidden="true"></div>
    <div class="absolute inset-0">
      <div class="container max-w-wide flex h-full items-start pt-8 md:items-center md:pt-0">
        <div class="max-w-2xl py-10 md:py-16">
          <img
            src="/images/brand/apex-logo-premium-cropped.png"
            alt="Apex Packaging"
            width="1300"
            height="476"
            class="mb-5 h-10 w-auto max-w-[12.5rem] object-contain object-left mix-blend-multiply md:mb-8 md:h-20 md:max-w-[22rem]"
            loading="eager"
            decoding="async"
          />
          <p class="eyebrow">Boxes By Style · CBD Boxes</p>
          <h1 class="mt-3 font-display text-[2.35rem] font-extrabold leading-[1.04] text-neutral-950 min-[390px]:text-[2.55rem] md:mt-4 md:text-6xl">
            Premium CBD boxes for retail, ecommerce, and launch-ready product lines.
          </h1>
          <p class="mt-4 max-w-xl text-base font-medium leading-relaxed text-neutral-700 md:mt-5 md:text-lg">
            Apex builds CBD packaging around your bottle, jar, gummy pouch, balm, or gift set with custom dielines, polished finishes, and practical production guidance.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class="inline-flex items-center justify-center rounded-md bg-accent px-6 py-3.5 font-display text-sm font-extrabold uppercase tracking-wide text-white shadow-[0_10px_22px_rgba(214,158,0,0.22)] transition-colors hover:bg-warning">
              Request a Quote
            </a>
            <a href="#styles" class="inline-flex items-center justify-center rounded-md border-2 border-neutral-900 px-6 py-3.5 font-display text-sm font-extrabold uppercase tracking-wide text-neutral-950 transition-colors hover:border-accent hover:text-accent">
              View Box Styles
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="styles" class="scroll-mt-28 bg-white py-14 md:scroll-mt-32 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-4">
          <p class="eyebrow">CBD packaging formats</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold leading-tight text-neutral-900 md:text-5xl">Choose the structure around the product and sales channel.</h2>
          <p class="mt-5 text-base leading-relaxed text-neutral-600 md:text-lg">
            A tincture carton, topical jar box, gummy sleeve, retail display, and ecommerce kit all need different board, closure, panel layout, and protection.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:col-span-8">
          {[
            ['Tuck cartons', 'Straight tuck, reverse tuck, and auto-bottom cartons for bottles, jars, and small retail units.'],
            ['Sleeve boxes', 'Clean outer sleeves for gummies, balms, wellness sets, and short-run seasonal graphics.'],
            ['Rigid gift boxes', 'Premium presentation boxes with inserts, pull tabs, foil, and soft-touch finish options.'],
            ['Display trays', 'Shelf-ready trays and counter displays for multi-SKU retail programs.']
          ].map(([title, copy]) => (
            <article class="rounded-md border border-neutral-200 bg-neutral-50 p-5 shadow-sm md:p-6">
              <h3 class="font-display text-xl font-extrabold text-neutral-950">{title}</h3>
              <p class="mt-3 leading-relaxed text-neutral-600">{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-[#f5f1e9] py-14 md:py-24">
    <div class="container max-w-wide">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">Packaging inspiration</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold leading-tight text-neutral-950 md:text-5xl">
          Five distinct looks for modern CBD product lines.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-neutral-600 md:text-lg">
          Explore fictional brand concepts across tinctures, gummies, topicals, gift sets, and retail displays. Every structure can be adapted to your dimensions, artwork, finishes, and compliance content.
        </p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:mt-14 lg:grid-cols-6">
        {packagingGallery.map((item, index) => (
          <article class:list={[
            'group overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-card',
            index < 3 ? 'lg:col-span-2' : 'lg:col-span-3'
          ]}>
            <div class="overflow-hidden bg-neutral-100">
              <img
                src={item.image}
                alt={item.alt}
                width="1000"
                height="1000"
                loading="lazy"
                decoding="async"
                class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.025]"
              />
            </div>
            <div class="flex items-end justify-between gap-4 p-5 md:p-6">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.16em] text-accent">{item.brand}</p>
                <h3 class="mt-1 font-display text-xl font-extrabold text-neutral-950 md:text-2xl">{item.title}</h3>
              </div>
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-neutral-950 text-sm font-black text-white">
                0{index + 1}
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-950 py-14 text-neutral-50 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-8 md:grid-cols-3">
        {[
          ['Compliance-ready panels', 'Reserve clean zones for client-supplied warnings, ingredients, batch codes, barcodes, and claim language.'],
          ['Premium finish options', 'Matte, soft-touch, foil, embossing, spot UV, kraft textures, and luxury rigid-board presentations.'],
          ['Sample-first workflow', 'Review dielines, proofs, and physical samples before committing to a larger production run.']
        ].map(([title, copy]) => (
          <article class="border-l-4 border-accent pl-5">
            <h3 class="font-display text-2xl font-extrabold">{title}</h3>
            <p class="mt-3 leading-relaxed text-neutral-300">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-neutral-50 py-14 md:py-24">
    <div class="container max-w-default prose-apex">
      <h2>What Apex needs to quote CBD boxes</h2>
      <ul>
        <li><strong>Product dimensions</strong> including bottle, jar, pouch, or set measurements.</li>
        <li><strong>Sales channel</strong> such as retail shelf, ecommerce mailer, wholesale case, or launch kit.</li>
        <li><strong>Material direction</strong> including kraft, SBS paperboard, rigid board, corrugated, or recycled-content goals.</li>
        <li><strong>Finish direction</strong> such as foil, embossing, matte, soft-touch, spot UV, or a clean uncoated kraft feel.</li>
        <li><strong>Artwork and compliance content</strong> supplied by your team for panel planning and proofing.</li>
      </ul>
    </div>
  </section>

  <FAQAccordion faqs={faqs} />

  <RelatedContent
    items={[
      { title: 'Custom Mailer Boxes', href: '/services/mailer-boxes', description: 'Printed ecommerce mailers for launch kits and subscription packaging.' },
      { title: 'Cosmetic Boxes', href: '/industries/cosmetic-boxes', description: 'Premium retail cartons for skincare, serums, jars, and beauty products.' },
      { title: 'Hemp Boxes', href: '/industries/hemp-boxes', description: 'Botanical packaging with kraft, SBS, sleeve, and display tray options.' }
    ]}
  />

  <CTABand
    heading="Need premium CBD boxes?"
    lead="Send product dimensions, quantity, artwork direction, and target delivery date. Apex will recommend a structure, material, finish, and sample path."
    primaryCta={{ label: 'Send your specs', href: '/contact' }}
  />
</BaseLayout>
