---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import RelatedContent from '../../components/sections/RelatedContent.astro';
import CTABand from '../../components/sections/CTABand.astro';
import { buildBreadcrumbSchema, buildFAQSchema, buildServiceSchema } from '../../lib/schema';
import { industryBoxes, type IndustryBox } from '../../data/industryBoxes';

export function getStaticPaths() {
  return industryBoxes.map((box) => ({
    params: { slug: box.slug },
    props: { box }
  }));
}

const { box } = Astro.props as { box: IndustryBox };
const related = industryBoxes.filter((item) => item.slug !== box.slug).slice(0, 3);
const heroImage = box.heroBanner ?? box.image;

const faqs = [
  {
    q: `Can Apex manufacture custom ${box.label.toLowerCase()} with my logo?`,
    a: `Yes. Apex can manufacture ${box.label.toLowerCase()} with brand print, custom dimensions, material selection, and production-ready dielines.`
  },
  {
    q: `What is the minimum order for ${box.label.toLowerCase()}?`,
    a: 'Minimums depend on material, print method, and box structure. Stock corrugated programs can start lower, while custom printed cartons and specialty finishes are quoted by run size.'
  },
  {
    q: 'Can I get a sample before production?',
    a: 'Yes. Apex can prepare a digital proof and quote pre-production samples so fit, structure, and print placement are confirmed before the full run.'
  }
];

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Boxes by Industry', url: '/industries' },
  { name: box.label, url: `/industries/${box.slug}` }
]);

const service = buildServiceSchema({
  name: `Custom ${box.label} manufacturer Canada`,
  description: box.summary,
  url: `/industries/${box.slug}`
});
---
<BaseLayout
  title={`${box.label} Manufacturer Canada — Custom Printed Packaging`}
  description={`${box.summary} Get custom sizes, materials, printing, samples, and production support from Apex Packaging.`}
  image={heroImage}
  schemaBlocks={[breadcrumb, service, buildFAQSchema(faqs)]}
>
  <section class="overflow-hidden border-b border-neutral-200 bg-white">
    <div class="container max-w-wide grid gap-6 py-9 md:min-h-[620px] md:gap-8 md:py-14 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-center lg:gap-12 lg:py-0">
      <div class="max-w-[650px] lg:py-16">
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.16em] text-accent md:mb-5 md:text-sm">Boxes by industry</p>
        <h1 class="font-display text-[2.55rem] font-extrabold leading-[1.03] tracking-normal text-neutral-900 md:text-6xl xl:text-7xl">
          Custom {box.label}
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-neutral-700 md:mt-7 md:text-xl">{box.summary}</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap md:mt-8 md:gap-4">
          <a href="/contact" class="btn-primary !bg-accent !text-neutral-900 hover:!bg-warning">Get Quote</a>
          <a href="#details" class="btn-secondary">View Details</a>
        </div>
        <div class="mt-6 grid max-w-xl grid-cols-3 gap-2 md:mt-10 md:gap-3">
          {box.bestFor.slice(0, 3).map((item) => (
            <span class="rounded-md bg-neutral-50 px-2 py-2 text-center text-[0.68rem] font-black uppercase leading-tight tracking-wide text-neutral-700 shadow-card backdrop-blur md:bg-white/90 md:px-3 md:text-left md:text-sm">{item}</span>
          ))}
        </div>
      </div>
      <figure class="relative min-h-[230px] rounded-md bg-neutral-50 md:min-h-[420px] md:rounded-none lg:min-h-[620px]">
        <img
          src={heroImage}
          alt=""
          width="2560"
          height="960"
          class="absolute inset-0 h-full w-full object-contain object-center"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          aria-hidden="true"
        />
      </figure>
    </div>
  </section>

  <section id="details" class="scroll-mt-28 bg-neutral-50 py-12 md:scroll-mt-32 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <p class="eyebrow">Manufacturer details</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold leading-tight text-neutral-900 md:text-5xl">
            Built around your product, channel, and reorder plan.
          </h2>
          <p class="mt-4 text-base leading-relaxed text-neutral-600 md:mt-5 md:text-lg">
            Apex starts with dimensions, product weight, retail or shipping use, print goals, and target quantity. From there, the team recommends structure, board grade, print method, and sample path.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:col-span-7 lg:gap-5">
          <article class="rounded-md border border-neutral-200 bg-white p-5 shadow-card md:p-6">
            <h3 class="font-display text-xl font-extrabold text-neutral-900">Best For</h3>
            <ul class="mt-4 space-y-2 text-neutral-600">
              {box.bestFor.map((item) => <li class="flex gap-2"><span class="font-bold text-accent">•</span><span>{item}</span></li>)}
            </ul>
          </article>
          <article class="rounded-md border border-neutral-200 bg-white p-5 shadow-card md:p-6">
            <h3 class="font-display text-xl font-extrabold text-neutral-900">Materials</h3>
            <ul class="mt-4 space-y-2 text-neutral-600">
              {box.materials.map((item) => <li class="flex gap-2"><span class="font-bold text-accent">•</span><span>{item}</span></li>)}
            </ul>
          </article>
          <article class="rounded-md border border-neutral-200 bg-white p-5 shadow-card md:p-6">
            <h3 class="font-display text-xl font-extrabold text-neutral-900">Box Styles</h3>
            <ul class="mt-4 space-y-2 text-neutral-600">
              {box.styles.map((item) => <li class="flex gap-2"><span class="font-bold text-accent">•</span><span>{item}</span></li>)}
            </ul>
          </article>
          <article class="rounded-md border border-neutral-200 bg-white p-5 shadow-card md:p-6">
            <h3 class="font-display text-xl font-extrabold text-neutral-900">Print Options</h3>
            <ul class="mt-4 space-y-2 text-neutral-600">
              {box.printOptions.map((item) => <li class="flex gap-2"><span class="font-bold text-accent">•</span><span>{item}</span></li>)}
            </ul>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-white py-12 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-4">
          <p class="eyebrow">How Apex builds it</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold leading-tight text-neutral-900 md:text-4xl">From dieline to production run.</h2>
        </div>
        <div class="grid gap-4 lg:col-span-8">
          {box.manufacturerNotes.map((note, index) => (
            <article class="grid gap-3 rounded-md border border-neutral-200 bg-neutral-50 p-4 shadow-sm md:grid-cols-[auto_1fr] md:items-center md:gap-4 md:p-5">
              <span class="grid h-12 w-12 place-items-center rounded-md bg-accent font-mono text-sm font-black text-neutral-900">0{index + 1}</span>
              <p class="text-base font-semibold leading-relaxed text-neutral-800 md:text-lg">{note}</p>
            </article>
          ))}
          <article class="grid gap-3 rounded-md border border-[#c8dbdd] bg-[#eef6f6] p-4 md:grid-cols-[auto_1fr] md:items-center md:gap-4 md:p-5">
            <span class="grid h-12 w-12 place-items-center rounded-md bg-[#1f6672] font-mono text-sm font-black text-white">RFQ</span>
            <p class="text-base font-semibold leading-relaxed text-neutral-800 md:text-lg">
              Send dimensions, quantity, artwork, product weight, and launch date. Apex will return a practical material, structure, and pricing recommendation.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <FAQAccordion faqs={faqs} />

  <RelatedContent
    items={related.map((item) => ({
      title: item.label,
      href: `/industries/${item.slug}`,
      description: item.summary
    }))}
  />

  <CTABand
    heading={`Need custom ${box.label.toLowerCase()}?`}
    lead="Share the product size, material preference, quantity, and target delivery date. Apex will recommend the right box structure and print path."
    primaryCta={{ label: 'Send your specs', href: '/contact' }}
  />
</BaseLayout>
