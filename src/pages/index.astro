---
import BaseLayout from '../layouts/BaseLayout.astro';
import PackagingIcon from '../components/ui/PackagingIcon.astro';
import { buildFAQSchema } from '../lib/schema';

const categories = [
  { title: 'Rigid Boxes', href: '/services/mailer-boxes', image: 'rigid-boxes' },
  { title: 'Custom Mylar Bags', href: '/services/polybags', image: 'custom-mylar-bags' },
  { title: 'Coffee Packaging', href: '/services/polybags', image: 'coffee-packaging' },
  { title: 'Custom Kraft Boxes', href: '/services/corrugated-boxes', image: 'custom-kraft-boxes' },
  { title: 'Gable Boxes', href: '/services/mailer-boxes', image: 'gable-boxes' },
  { title: 'Cosmetic Boxes', href: '/services/mailer-boxes', image: 'cosmetic-boxes' },
  { title: 'Candle Boxes', href: '/services/mailer-boxes', image: 'candle-boxes' },
  { title: 'Soap Boxes', href: '/services/mailer-boxes', image: 'soap-boxes' },
  { title: 'Bakery Boxes', href: '/services/corrugated-boxes', image: 'bakery-boxes' },
  { title: 'Display Boxes', href: '/services/corrugated-boxes', image: 'display-boxes' },
  { title: 'Food Boxes', href: '/services/corrugated-boxes', image: 'food-boxes' },
  { title: 'Pillow Boxes', href: '/services/mailer-boxes', image: 'pillow-boxes' },
  { title: 'Chocolate Boxes', href: '/services/mailer-boxes', image: 'chocolate-boxes' },
  { title: 'Window Packaging', href: '/services/mailer-boxes', image: 'window-packaging' },
  { title: 'Gift Boxes', href: '/services/mailer-boxes', image: 'gift-boxes' },
  { title: 'Custom Tuck Boxes', href: '/services/mailer-boxes', image: 'custom-tuck-boxes' },
  { title: 'Tea Packaging', href: '/services/polybags', image: 'tea-packaging' },
  { title: 'Christmas Boxes', href: '/services/mailer-boxes', image: 'christmas-boxes' },
  { title: 'Custom Kraft Soap Boxes', href: '/services/mailer-boxes', image: 'custom-kraft-soap-boxes' },
  { title: 'Chocolate Bar Boxes', href: '/services/mailer-boxes', image: 'chocolate-bar-boxes' },
  { title: 'Software Boxes', href: '/services/mailer-boxes', image: 'software-boxes' },
  { title: 'Hair Extension Boxes', href: '/services/mailer-boxes', image: 'hair-extension-boxes' },
  { title: 'CBD Gift Boxes', href: '/services/mailer-boxes', image: 'cbd-gift-boxes' }
];

const benefitStrip = [
  { step: 'Quote', title: 'No Die & Plate Charges', stat: 'No setup drag', icon: 'quote-review', body: 'Digital proofs and low-run production keep the first order simple.' },
  { step: 'Proof', title: 'Free Design Support', stat: 'Dieline included', icon: 'design-proof', body: 'Dielines, print prep, and mockups are included with qualifying orders.' },
  { step: 'Sample', title: 'Starting From 50 Boxes', stat: '50 box starts', icon: 'sample-run', body: 'Digital sample runs help you validate packaging before scaling.' },
  { step: 'Specify', title: 'Customize Size & Style', stat: 'Built to fit', icon: 'custom-spec', body: 'Boxes, bags, trays, sleeves, inserts, and finishes built around your product.' },
  { step: 'Produce', title: 'Quick Turnaround Time', stat: '7-14 days', icon: 'production-window', body: 'Standard custom orders move from approval to production in 7-14 days.' },
  { step: 'Ship', title: 'Free Shipping', stat: 'USA & Canada', icon: 'domestic-shipping', body: 'Apex Packaging provides complimentary shipping throughout the USA and Canada.' }
];

const finishes = [
  { title: 'Holographic Foiling', image: 'holographic-foiling' },
  { title: 'Gold Foiling', image: 'gold-foiling' },
  { title: 'Embossing', image: 'embossing' },
  { title: 'Matte Lamination', image: 'matte-lamination' },
  { title: 'Spot UV', image: 'spot-uv' },
  { title: 'Soft Touch', image: 'soft-touch' }
];

const reasons = [
  { title: 'Customize Size and Shape', icon: 'custom-size-shape', body: 'Apex builds every package around the product dimensions, retail channel, and shipping environment.' },
  { title: 'Sustainable Material Options', icon: 'sustainable-materials', body: 'FSC corrugated, recycled liner, kraft board, compostable polybag options, and soy-based inks are available.' },
  { title: 'High-End Printing Quality', icon: 'printing-quality', body: 'Flexo, digital, and litho-laminated print options cover short runs, retail graphics, and industrial markings.' },
  { title: 'Premium Finishing Features', icon: 'premium-finishes', body: 'Foil, embossing, spot UV, matte lamination, and soft-touch finishes help retail packaging stand out.' },
  { title: 'Fast Delivery', icon: 'canadian-delivery', body: 'Our streamlined shipping process helps reduce freight delays and keeps your launch schedules on track.' },
  { title: 'Design Support Included', icon: 'design-support', body: 'Send your logo and product dimensions; Apex returns a dieline, proof, and production-ready artwork.' },
  { title: 'Low MOQ Flexibility', icon: 'low-moq', body: 'Start with sample or short-run quantities before committing to a full pallet.' },
  { title: 'Procurement-Ready Specs', icon: 'procurement-specs', body: 'Quotes include material, board strength, print method, MOQ, lead time, and reorder details.' }
];

const clientNames = ['Food Brands', 'D2C Teams', 'Industrial Supply', 'Coffee Roasters', 'Cosmetics', 'Retail Launches', 'Pharma', 'Auto Parts', 'Electronics'];

const faqs = [
  { q: 'What is the minimum order quantity?', a: 'MOQs start at 100 units on stock RSC corrugated, 250 units on custom-printed flexo mailers, and 500 units on custom-print polybags. Digital-print sampling can start lower.' },
  { q: 'What is the typical lead time?', a: 'Production runs usually ship within 7-14 days from artwork sign-off. Rush timelines are quoted by product, print method, and material availability.' },
  { q: 'Can Apex help with artwork and dielines?', a: 'Yes. Apex can create the dieline, prepare artwork, generate a proof, and keep the final files on record for reorders.' }
];

const heroSlides = [
  {
    src: '/images/apex-update/banners/banner-1.webp',
    alt: 'Custom packaging collection with fictional brand designs'
  },
  {
    src: '/images/apex-update/banners/banner-2.webp',
    alt: 'Colorful retail packaging with original mock brands'
  },
  {
    src: '/images/apex-update/banners/banner-3.webp',
    alt: 'Sustainable packaging with fictional brand artwork'
  }
];

const schemaBlocks = [buildFAQSchema(faqs)];
---
<BaseLayout
  title="Custom Packaging Canada | Apex Packaging"
  description="Apex Packaging Solutions manufactures custom printed boxes, bags, mailers, inserts, and retail packaging in Canada with low MOQs, fast turnaround, and design support."
  schemaBlocks={schemaBlocks}
>
  <section class="apex-banner-slider overflow-hidden border-b border-neutral-200 bg-white">
    <h1 class="sr-only">Custom Packaging your customers will love</h1>
    <div class="relative aspect-[2172/724] w-full">
      {heroSlides.map((slide, index) => (
        <img
          src={slide.src}
          alt={slide.alt}
          width="2172"
          height="724"
          class="apex-banner-slide absolute inset-0 h-full w-full object-cover object-center"
          style={`animation-delay: ${index * 5}s;`}
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={index === 0 ? 'high' : 'auto'}
        />
      ))}
    </div>
  </section>

  <style>
    .apex-banner-slide {
      animation: apex-banner-fade 15s infinite;
      opacity: 0;
    }

    @keyframes apex-banner-fade {
      0%,
      30% {
        opacity: 1;
      }

      36%,
      94% {
        opacity: 0;
      }

      100% {
        opacity: 0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .apex-banner-slide {
        animation: none;
        opacity: 0;
      }

      .apex-banner-slide:first-child {
        opacity: 1;
      }
    }
  </style>

  <section class="border-y border-neutral-200 bg-neutral-50 py-3 md:py-5">
    <div class="container max-w-wide overflow-hidden">
      <div class="flex min-w-max items-center gap-6 text-center text-xs font-black uppercase tracking-wide text-neutral-400 md:gap-10 md:text-sm">
        {[...clientNames, ...clientNames].map((name) => <span>{name}</span>)}
      </div>
    </div>
  </section>

  <section id="categories" class="bg-white py-12 md:py-24">
    <div class="container max-w-wide">
      <div class="mx-auto mb-8 max-w-4xl text-center md:mb-12">
        <h2 class="font-display text-3xl font-extrabold uppercase leading-tight text-neutral-900 md:text-5xl">Your Custom Packaging Partner</h2>
        <p class="mt-3 text-base leading-relaxed text-neutral-600 md:mt-4 md:text-lg">
          Choose the packaging category that matches your product, then send the size, quantity, print requirements, and launch date.
        </p>
      </div>
      <div class="-mx-4 flex snap-x gap-4 overflow-x-auto px-4 pb-3 [scrollbar-width:none] md:mx-0 md:grid md:grid-cols-3 md:gap-x-5 md:gap-y-12 md:overflow-visible md:px-0 md:pb-0 lg:grid-cols-4 [&::-webkit-scrollbar]:hidden">
        {categories.map((cat) => (
          <a href={cat.href} class="group w-[42vw] max-w-[12rem] shrink-0 snap-start text-center md:w-auto md:max-w-none">
            <img
              src={`/images/home/categories/${cat.image}.webp`}
              alt={`${cat.title} product packaging`}
              width="418"
              height="418"
              loading="lazy"
              decoding="async"
              class="aspect-square w-full rounded-md object-cover shadow-sm transition-transform duration-200 group-hover:-translate-y-1 md:rounded-none md:shadow-none"
            />
            <h3 class="mt-3 font-display text-sm font-extrabold uppercase tracking-normal text-neutral-900 md:mt-5 md:text-xl">{cat.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-neutral-100 py-12 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow">RFQ to reorder</p>
          <h2 class="mt-3 max-w-5xl font-display text-3xl font-extrabold uppercase leading-tight text-neutral-900 md:text-5xl">
            Quote, proof, produce, reorder
          </h2>
          <p class="mt-3 max-w-3xl text-base leading-relaxed text-neutral-600 md:mt-4 md:text-lg">
            Apex brings custom packaging pricing, dielines, materials, production timing, and shipping clarity into one clear workflow.
          </p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <a href="#quote" class="btn-primary !bg-accent !text-neutral-900 hover:!bg-warning">Start a quote</a>
        </div>
      </div>

      <div class="relative mt-8 md:mt-12">
        <div class="absolute left-0 right-0 top-[46px] hidden h-px bg-neutral-300 lg:block"></div>
        <div class="-mx-4 flex snap-x gap-4 overflow-x-auto px-4 pb-3 [scrollbar-width:none] sm:mx-0 sm:grid sm:grid-cols-2 sm:overflow-visible sm:px-0 sm:pb-0 lg:grid-cols-6 [&::-webkit-scrollbar]:hidden">
          {benefitStrip.map((item, index) => (
            <article class="group relative flex h-full min-h-[320px] w-[82vw] max-w-[22rem] shrink-0 snap-start flex-col rounded-md border border-neutral-200 bg-white p-5 shadow-card transition duration-300 hover:-translate-y-2 hover:border-[#7fb4bb] hover:shadow-popover sm:w-auto sm:max-w-none lg:min-h-[390px]">
              <div class="mb-5 flex items-center justify-between gap-3">
                <span class="grid h-16 w-16 place-items-center rounded-lg border border-[#c8dbdd] bg-[#eef6f6] text-[#1f6672] shadow-sm transition duration-300 group-hover:-translate-y-1 group-hover:border-[#7fb4bb] group-hover:bg-[#e0eff1]">
                  <PackagingIcon name={item.icon} class="h-9 w-9" />
                </span>
                <span class="rounded-md bg-[#eef6f6] px-2.5 py-1 text-xs font-black uppercase tracking-wide text-[#1f6672] transition duration-300 group-hover:bg-[#1f6672] group-hover:text-white">0{index + 1}</span>
              </div>
              <p class="text-xs font-black uppercase tracking-[0.16em] text-neutral-500">{item.step}</p>
              <h3 class="mt-2 font-display text-lg font-extrabold uppercase leading-tight text-neutral-900 lg:min-h-[4.75rem]">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-neutral-600 lg:min-h-[8.25rem]">{item.body}</p>
              <div class="mt-auto border-t border-neutral-200 pt-4 text-sm font-black uppercase tracking-wide text-success">{item.stat}</div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 md:py-24">
    <div class="container max-w-wide">
      <div class="mb-8 text-center md:mb-12">
        <h2 class="font-display text-3xl font-extrabold uppercase text-neutral-900 md:text-5xl">Premium Finishes</h2>
        <p class="mt-3 text-base text-neutral-600">Finishing options that give custom boxes a premium retail feel.</p>
      </div>
      <div class="-mx-4 flex snap-x gap-4 overflow-x-auto px-4 pb-3 [scrollbar-width:none] md:mx-0 md:grid md:grid-cols-3 md:gap-6 md:overflow-visible md:px-0 md:pb-0 [&::-webkit-scrollbar]:hidden">
        {finishes.map((finish) => (
          <a href="/design-support" class="group relative block w-[82vw] max-w-[24rem] shrink-0 snap-start overflow-hidden rounded-md bg-neutral-900 md:w-auto md:max-w-none">
            <img
              src={`/images/home/finishes/${finish.image}.webp`}
              alt={`${finish.title} packaging finish`}
              width="768"
              height="341"
              loading="lazy"
              decoding="async"
              class="aspect-[16/9] w-full object-cover opacity-85 transition duration-200 group-hover:scale-[1.03] group-hover:opacity-100"
            />
            <h3 class="absolute bottom-4 left-4 font-display text-xl font-extrabold text-neutral-50">{finish.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section
    class="relative overflow-hidden bg-neutral-900 bg-cover bg-center bg-no-repeat py-12 md:bg-fixed md:py-24"
    style="background-image: url('/images/home/why-choose-parallax-bg.webp');"
  >
    <div class="absolute inset-0 bg-neutral-950/76"></div>
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(9,8,5,0.92)_0%,rgba(9,8,5,0.78)_48%,rgba(9,8,5,0.58)_100%)]"></div>
    <div class="container max-w-wide relative">
      <div class="max-w-4xl">
        <p class="eyebrow">Why Apex</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold text-neutral-50 md:text-6xl">Why Choose Us?</h2>
        <p class="mt-3 max-w-2xl text-base font-semibold uppercase tracking-wide text-neutral-200 md:mt-4 md:text-lg">
          Custom packaging support from brief to reorder.
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 md:mt-12 md:gap-5 lg:grid-cols-4">
        {reasons.map((reason) => (
          <div class="rounded-md border border-white/15 bg-neutral-950/58 p-4 shadow-popover backdrop-blur-sm md:min-h-[260px] md:p-5">
            <span class="mb-4 grid h-14 w-14 place-items-center rounded-lg border border-white/15 bg-white/10 text-[#8fd0cf] shadow-card md:mb-5 md:h-[72px] md:w-[72px]">
              <PackagingIcon name={reason.icon} class="h-10 w-10" />
            </span>
            <h3 class="font-display text-lg font-extrabold text-neutral-50 md:text-xl">{reason.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-200 md:mt-3 md:text-base">{reason.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-12 md:py-24">
    <div class="container max-w-wide grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <h2 class="font-display text-3xl font-extrabold uppercase text-neutral-900 md:text-5xl">Client Testimonial</h2>
        <p class="mt-3 font-semibold uppercase tracking-wide text-neutral-600">Service that keeps launches moving.</p>
        <div class="mt-6 text-5xl font-black leading-none text-accent md:mt-8 md:text-6xl">"</div>
        <blockquote class="mt-3 max-w-2xl text-lg font-semibold italic leading-relaxed text-neutral-800 md:mt-4 md:text-xl">
          Apex helped us move from rough packaging dimensions to a production-ready dieline quickly. The print proof was clear, the material options were practical, and the reorder file saved our team time.
        </blockquote>
        <div class="mt-8 flex items-center gap-4">
          <div class="grid h-16 w-16 place-items-center rounded-md bg-accent font-display text-xl font-extrabold text-neutral-900">PM</div>
          <div>
            <div class="font-bold text-neutral-900">Procurement Manager</div>
            <div class="text-sm text-neutral-500">Canadian consumer goods brand</div>
            <div class="mt-1 text-accent">★★★★★</div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-6">
        <div class="grid grid-cols-2 gap-3 md:gap-4">
          {['corrugated-boxes-branded', 'polybags-branded', 'categories/cosmetic-boxes', 'hero-branded-packaging'].map((img) => (
            <img
              src={`/images/home/${img}.webp`}
              alt="Custom packaging example with fictional brand artwork"
              width="1536"
              height="1024"
              loading="lazy"
              decoding="async"
              class="aspect-square w-full rounded-md object-cover shadow-card md:rounded-full"
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="quote" class="scroll-mt-28 bg-neutral-100 py-12 md:scroll-mt-32 md:py-24">
    <div class="container max-w-wide">
      <div class="mb-8 max-w-4xl md:mb-10">
        <p class="eyebrow">RFQ desk</p>
        <div class="mt-3 flex flex-wrap items-end gap-x-6 gap-y-3">
          <h2 class="font-display text-3xl font-extrabold uppercase leading-none text-neutral-900 md:text-5xl">Get Custom Quote</h2>
          <span class="mb-1 rounded-md bg-white px-4 py-2 text-sm font-black uppercase tracking-wide text-success shadow-card">Free shipping review</span>
        </div>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-neutral-600 md:mt-4 md:text-lg">
          Send the package size, material, quantity, and launch timing. Apex reviews the spec and responds with a practical production path.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-12 lg:items-center xl:gap-10">
        <form class="overflow-hidden rounded-[2rem] rounded-tr-[3.75rem] border border-[#d8cba7] bg-neutral-100 shadow-popover lg:col-span-7" action="/api/quote" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="source" value="Home Quote Form" />
          <input type="hidden" name="redirectTo" value="/thank-you" />
          <label class="hidden" aria-hidden="true">
            Website
            <input name="website" tabindex="-1" autocomplete="off" />
          </label>
          <div class="bg-accent px-5 py-5 text-center md:px-7">
            <h3 class="font-display text-2xl font-extrabold uppercase tracking-wide text-neutral-900 md:text-3xl">Get Custom Quote</h3>
          </div>

          <div class="grid gap-5 p-4 md:p-7">
            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <PackagingIcon name="quote-review" class="h-4 w-4" />
                </span>
                Product Information
              </legend>
              <input class="h-12 border border-transparent bg-white px-4 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="product" placeholder="Product Name" />
            </fieldset>

            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <PackagingIcon name="custom-spec" class="h-4 w-4" />
                </span>
                Select Sizes
              </legend>
              <div class="grid gap-2 sm:grid-cols-[1fr_1fr_1fr_0.82fr]">
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="length" placeholder="Length" />
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="width" placeholder="Width" />
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="depth" placeholder="Depth" />
                <select class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-700 focus:border-accent" name="unit">
                  <option>Unit</option>
                  <option>inch</option>
                  <option>cm</option>
                  <option>mm</option>
                </select>
              </div>
            </fieldset>

            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <PackagingIcon name="sample-run" class="h-4 w-4" />
                </span>
                Choose Materials
              </legend>
              <div class="grid gap-2 sm:grid-cols-[1fr_1fr_0.85fr]">
                <select class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-700 focus:border-accent" name="material">
                  <option>Stock</option>
                  <option>Cardboard Boxes</option>
                  <option>Kraft Boxes</option>
                  <option>Rigid Boxes</option>
                  <option>Corrugated Boxes</option>
                </select>
                <select class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-700 focus:border-accent" name="printing">
                  <option>Printing</option>
                  <option>Full-color exterior</option>
                  <option>Inside and outside print</option>
                  <option>No print</option>
                </select>
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="quantity" placeholder="Quantity" />
              </div>
            </fieldset>

            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <PackagingIcon name="design-proof" class="h-4 w-4" />
                </span>
                Upload Artwork
              </legend>
              <label class="flex min-h-12 cursor-pointer items-center bg-white px-4 text-sm font-semibold text-neutral-500 transition hover:ring-1 hover:ring-accent">
                <input class="text-sm" name="artwork" type="file" />
              </label>
            </fieldset>

            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5Zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5Z"></path>
                  </svg>
                </span>
                Personal Information
              </legend>
              <div class="grid gap-2 sm:grid-cols-3">
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="name" placeholder="Full Name*" />
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="email" placeholder="Email ID*" />
                <input class="h-12 border border-transparent bg-white px-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="phone" placeholder="Contact Number*" />
              </div>
            </fieldset>

            <fieldset class="grid gap-3">
              <legend class="mb-1 flex items-center gap-2 font-display text-base font-extrabold text-neutral-800">
                <span class="grid h-6 w-6 place-items-center rounded bg-accent text-neutral-900" aria-hidden="true">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M11 7h2v2h-2Zm0 4h2v6h-2Zm1-9a10 10 0 1 0 10 10A10.01 10.01 0 0 0 12 2Z"></path>
                  </svg>
                </span>
                Additional Information
              </legend>
              <textarea class="min-h-28 border border-transparent bg-white px-4 py-3 text-sm font-semibold text-neutral-900 placeholder:text-neutral-400 focus:border-accent" name="message" placeholder="Message..."></textarea>
            </fieldset>

            <div class="grid gap-4 pt-1 sm:grid-cols-[1fr_auto] sm:items-center">
              <div class="flex min-h-16 max-w-xs items-center gap-3 border border-neutral-300 bg-white px-4 text-sm font-semibold text-neutral-600">
                <span class="h-7 w-7 border border-neutral-500 bg-white" aria-hidden="true"></span>
                I'm not a robot
                <span class="ml-auto text-[0.65rem] font-black uppercase text-neutral-400">reCAPTCHA</span>
              </div>
              <button class="min-h-12 rounded-md bg-accent px-10 py-3 font-black text-neutral-900 transition hover:bg-warning" type="submit">Submit</button>
            </div>
          </div>
        </form>

        <aside class="lg:col-span-5">
          <div class="max-w-2xl">
            <h3 class="font-display text-3xl font-extrabold leading-tight text-neutral-900 md:text-4xl">
              Custom Boxes, Designed for Your Brand, Made for Your Needs - Without the Hassle.
            </h3>
            <p class="mt-5 text-base font-semibold leading-relaxed text-neutral-600">
              Ensuring the perfect fit, protection, branding, and presentation for your custom boxes is effortless with Apex's comprehensive support.
            </p>
            <p class="mt-4 text-base font-semibold leading-relaxed text-neutral-600">
              Get expert guidance, access proven box styles, and find the right size by sending your product details. Apex helps select materials, printing techniques, finishes, laminations, and add-ons tailored to your packaging needs and purpose.
            </p>
            <h4 class="mt-7 font-display text-xl font-extrabold text-neutral-900">Still, There's More!</h4>
            <p class="mt-3 text-base font-semibold leading-relaxed text-neutral-600">
              Upload your logo or artwork, and our packaging designers can refine it to match your brand identity while keeping the structure practical for production.
            </p>
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {[
                'New look for your brand',
                'Perfect fit to your products',
                'Perfect fit to your purpose',
                'All with convenience quick'
              ].map((item) => (
                <div class="flex min-h-16 items-center gap-3 rounded-md border border-[#ead58d] bg-[#fff8df] px-4 font-display text-sm font-extrabold text-neutral-800">
                  <span class="grid h-5 w-5 shrink-0 place-items-center rounded-full bg-accent text-neutral-900" aria-hidden="true">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 12 4 4 8-8"></path>
                    </svg>
                  </span>
                  {item}
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 md:py-24">
    <div class="container max-w-wide">
      <h2 class="font-display text-2xl font-extrabold text-neutral-900 md:text-4xl">Get Your Custom Boxes with Logo for Every Product at Wholesale Rate</h2>
      <p class="mt-4 max-w-5xl text-base leading-relaxed text-neutral-600 md:mt-5 md:text-lg">
        Apex Packaging Solutions manufactures custom printed boxes, mailers, bags, trays, sleeves, and protective packaging for brands that need product-ready packaging without long overseas timelines. Choose a category, send the product dimensions, and Apex will help select material, structure, print method, finishing, and shipment timing.
      </p>
    </div>
  </section>

  <section class="bg-neutral-900 py-10 text-neutral-50">
    <div class="container max-w-wide -mx-4 flex snap-x gap-4 overflow-x-auto px-4 [scrollbar-width:none] md:mx-auto md:grid md:grid-cols-5 md:overflow-visible md:px-10 [&::-webkit-scrollbar]:hidden">
      {categories.slice(-5).map((cat) => (
        <a href={cat.href} class="w-[48vw] max-w-[13rem] shrink-0 snap-start text-center md:w-auto md:max-w-none">
          <img
            src={`/images/home/categories/${cat.image}.webp`}
            alt={`${cat.title} product packaging`}
            width="418"
            height="418"
            loading="lazy"
            decoding="async"
            class="aspect-square w-full rounded-md object-cover md:rounded-none"
          />
          <span class="mt-3 block font-display text-sm font-bold md:text-lg">{cat.title}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
