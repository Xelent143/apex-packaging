---
import BaseLayout from '../layouts/BaseLayout.astro';
import PackagingIcon from '../components/ui/PackagingIcon.astro';
import { buildFAQSchema } from '../lib/schema';

const categories = [
  { title: 'Rigid Boxes', href: '/services/mailer-boxes', image: 'rigid-boxes' },
  { title: 'Custom Mylar Bags', href: '/services/polybags', image: 'custom-mylar-bags' },
  { title: 'Coffee Packaging', href: '/services/polybags', image: 'coffee-packaging' },
  { title: 'Custom Kraft Boxes', href: '/services/corrugated-boxes', image: 'custom-kraft-boxes' },
  { title: 'Gable Boxes', href: '/services/mailer-boxes', image: 'gable-boxes' },
  { title: 'Cosmetic Boxes', href: '/services/mailer-boxes', image: 'cosmetic-boxes' },
  { title: 'Candle Boxes', href: '/services/mailer-boxes', image: 'candle-boxes' },
  { title: 'Soap Boxes', href: '/services/mailer-boxes', image: 'soap-boxes' },
  { title: 'Bakery Boxes', href: '/services/corrugated-boxes', image: 'bakery-boxes' },
  { title: 'Display Boxes', href: '/services/corrugated-boxes', image: 'display-boxes' },
  { title: 'Food Boxes', href: '/services/corrugated-boxes', image: 'food-boxes' },
  { title: 'Pillow Boxes', href: '/services/mailer-boxes', image: 'pillow-boxes' },
  { title: 'Chocolate Boxes', href: '/services/mailer-boxes', image: 'chocolate-boxes' },
  { title: 'Window Packaging', href: '/services/mailer-boxes', image: 'window-packaging' },
  { title: 'Gift Boxes', href: '/services/mailer-boxes', image: 'gift-boxes' },
  { title: 'Custom Tuck Boxes', href: '/services/mailer-boxes', image: 'custom-tuck-boxes' },
  { title: 'Trays and Sleeves', href: '/services/protective-packaging', image: 'trays-and-sleeves' },
  { title: 'Tin Packaging', href: '/services/industrial-bulk-packaging', image: 'tin-packaging' },
  { title: 'Tea Packaging', href: '/services/polybags', image: 'tea-packaging' },
  { title: 'Christmas Boxes', href: '/services/mailer-boxes', image: 'christmas-boxes' },
  { title: 'Custom Kraft Soap Boxes', href: '/services/mailer-boxes', image: 'custom-kraft-soap-boxes' },
  { title: 'Chocolate Bar Boxes', href: '/services/mailer-boxes', image: 'chocolate-bar-boxes' },
  { title: 'Software Boxes', href: '/services/mailer-boxes', image: 'software-boxes' },
  { title: 'Hair Extension Boxes', href: '/services/mailer-boxes', image: 'hair-extension-boxes' },
  { title: 'CBD Gift Boxes', href: '/services/mailer-boxes', image: 'cbd-gift-boxes' }
];

const benefitStrip = [
  { step: 'Quote', title: 'No Die & Plate Charges', stat: 'No setup drag', icon: 'quote-review', body: 'Digital proofs and low-run production keep the first order simple.' },
  { step: 'Proof', title: 'Free Design Support', stat: 'Dieline included', icon: 'design-proof', body: 'Dielines, print prep, and mockups are included with qualifying orders.' },
  { step: 'Sample', title: 'Starting From 50 Boxes', stat: '50 box starts', icon: 'sample-run', body: 'Digital sample runs help you validate packaging before scaling.' },
  { step: 'Specify', title: 'Customize Size & Style', stat: 'Built to fit', icon: 'custom-spec', body: 'Boxes, bags, trays, sleeves, inserts, and finishes built around your product.' },
  { step: 'Produce', title: 'Quick Turnaround Time', stat: '7-14 days', icon: 'production-window', body: 'Standard custom orders move from approval to production in 7-14 days.' },
  { step: 'Ship', title: 'Domestic Shipping', stat: 'Canada-wide', icon: 'domestic-shipping', body: 'Apex ships from Canada across provinces by parcel, LTL, and FTL.' }
];

const finishes = [
  { title: 'Holographic Foiling', image: 'holographic-foiling' },
  { title: 'Gold Foiling', image: 'gold-foiling' },
  { title: 'Embossing', image: 'embossing' },
  { title: 'Matte Lamination', image: 'matte-lamination' },
  { title: 'Spot UV', image: 'spot-uv' },
  { title: 'Soft Touch', image: 'soft-touch' }
];

const reasons = [
  { title: 'Customize Size and Shape', icon: 'custom-size-shape', body: 'Apex builds every package around the product dimensions, retail channel, and shipping environment.' },
  { title: 'Sustainable Material Options', icon: 'sustainable-materials', body: 'FSC corrugated, recycled liner, kraft board, compostable polybag options, and soy-based inks are available.' },
  { title: 'High-End Printing Quality', icon: 'printing-quality', body: 'Flexo, digital, and litho-laminated print options cover short runs, retail graphics, and industrial markings.' },
  { title: 'Premium Finishing Features', icon: 'premium-finishes', body: 'Foil, embossing, spot UV, matte lamination, and soft-touch finishes help retail packaging stand out.' },
  { title: 'Fast Canadian Delivery', icon: 'canadian-delivery', body: 'Domestic production avoids overseas freight delays and keeps launch schedules under control.' },
  { title: 'Design Support Included', icon: 'design-support', body: 'Send your logo and product dimensions; Apex returns a dieline, proof, and production-ready artwork.' },
  { title: 'Low MOQ Flexibility', icon: 'low-moq', body: 'Start with sample or short-run quantities before committing to a full pallet.' },
  { title: 'Procurement-Ready Specs', icon: 'procurement-specs', body: 'Quotes include material, board strength, print method, MOQ, lead time, and reorder details.' }
];

const clientNames = ['Food Brands', 'D2C Teams', 'Industrial Supply', 'Coffee Roasters', 'Cosmetics', 'Retail Launches', 'Pharma', 'Auto Parts', 'Electronics'];

const faqs = [
  { q: 'What is the minimum order quantity?', a: 'MOQs start at 100 units on stock RSC corrugated, 250 units on custom-printed flexo mailers, and 500 units on custom-print polybags. Digital-print sampling can start lower.' },
  { q: 'What is the typical lead time?', a: 'Production runs usually ship within 7-14 days from artwork sign-off. Rush timelines are quoted by product, print method, and material availability.' },
  { q: 'Can Apex help with artwork and dielines?', a: 'Yes. Apex can create the dieline, prepare artwork, generate a proof, and keep the final files on record for reorders.' }
];

const schemaBlocks = [buildFAQSchema(faqs)];
---
<BaseLayout
  title="Custom Packaging Canada — Boxes, Bags, Mailers & Retail Packaging"
  description="Apex Packaging Solutions manufactures custom printed boxes, bags, mailers, inserts, and retail packaging in Canada with low MOQs, fast turnaround, and design support."
  schemaBlocks={schemaBlocks}
>
  <section class="relative isolate overflow-hidden bg-[#dfddda]">
    <img
      src="/images/home/hero-packaging-banner-apex.webp"
      alt=""
      width="1774"
      height="887"
      class="absolute inset-0 -z-10 h-full w-full origin-center object-cover object-[68%_center] opacity-35 md:translate-x-[5%] md:scale-[1.06] md:opacity-100"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(229,227,224,0.99)_0%,rgba(229,227,224,0.96)_38%,rgba(229,227,224,0.62)_58%,rgba(229,227,224,0.12)_80%,rgba(229,227,224,0)_100%)]"></div>
    <div class="absolute inset-y-0 left-0 -z-10 w-full bg-[linear-gradient(180deg,rgba(229,227,224,0.24)_0%,rgba(229,227,224,0)_28%,rgba(229,227,224,0.18)_100%)]"></div>
    <div class="container max-w-wide flex min-h-[560px] items-center py-14 md:min-h-[620px] md:py-16 lg:min-h-[650px]">
      <div class="max-w-[760px]">
        <p class="mb-5 text-sm font-bold uppercase tracking-[0.16em] text-accent">Custom printed packaging</p>
        <h1 class="font-display text-5xl font-extrabold leading-[1.04] tracking-normal text-neutral-900 md:text-7xl">
          <span class="block">Custom</span>
          <span class="block">Packaging your</span>
          <span class="block text-[0.7em] font-medium md:text-[0.78em]">customers will love</span>
        </h1>
        <p class="mt-7 max-w-xl text-xl leading-relaxed text-neutral-700">
          Boxes, bags, mailers, trays, sleeves, and premium finishes produced for Canadian brands that need packaging to look sharp and ship on time.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary !bg-accent !text-neutral-900 hover:!bg-warning">Get Quote</a>
          <a href="#categories" class="btn-secondary">Browse Products</a>
        </div>
        <div class="mt-10 flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-wide text-neutral-600">
          <span class="rounded-md bg-white/90 px-3 py-2 shadow-card backdrop-blur">BBB A+ rated</span>
          <span class="rounded-md bg-white/90 px-3 py-2 shadow-card backdrop-blur">Google reviewed</span>
          <span class="rounded-md bg-white/90 px-3 py-2 shadow-card backdrop-blur">7-14 day production</span>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-50 py-5">
    <div class="container max-w-wide overflow-hidden">
      <div class="flex min-w-max items-center gap-10 text-center text-sm font-black uppercase tracking-wide text-neutral-400">
        {[...clientNames, ...clientNames].map((name) => <span>{name}</span>)}
      </div>
    </div>
  </section>

  <section id="categories" class="bg-white py-16 md:py-24">
    <div class="container max-w-wide">
      <div class="mx-auto mb-12 max-w-4xl text-center">
        <h2 class="font-display text-4xl font-extrabold uppercase leading-tight text-neutral-900 md:text-5xl">Your Custom Packaging Partner</h2>
        <p class="mt-4 text-lg leading-relaxed text-neutral-600">
          Choose the packaging category that matches your product, then send the size, quantity, print requirements, and launch date.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-x-5 gap-y-12 md:grid-cols-3 lg:grid-cols-4">
        {categories.map((cat) => (
          <a href={cat.href} class="group text-center">
            <img
              src={`/images/home/categories/${cat.image}.webp`}
              alt={`${cat.title} product packaging`}
              width="418"
              height="418"
              loading="lazy"
              decoding="async"
              class="aspect-square w-full object-cover transition-transform duration-200 group-hover:-translate-y-1"
            />
            <h3 class="mt-5 font-display text-lg font-extrabold uppercase tracking-tight text-neutral-900 md:text-xl">{cat.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-neutral-100 py-16 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow">RFQ to reorder</p>
          <h2 class="mt-3 max-w-5xl font-display text-4xl font-extrabold uppercase leading-tight text-neutral-900 md:text-5xl">
            Quote, proof, produce, reorder
          </h2>
          <p class="mt-4 max-w-3xl text-lg leading-relaxed text-neutral-600">
            Apex brings custom packaging pricing, dielines, materials, production timing, and domestic shipping into one clear workflow.
          </p>
        </div>
        <div class="lg:col-span-4 lg:text-right">
          <a href="#quote" class="btn-primary !bg-accent !text-neutral-900 hover:!bg-warning">Start a quote</a>
        </div>
      </div>

      <div class="relative mt-12">
        <div class="absolute left-0 right-0 top-[46px] hidden h-px bg-neutral-300 lg:block"></div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
          {benefitStrip.map((item, index) => (
            <article class="group relative flex h-full min-h-[390px] flex-col rounded-md border border-neutral-200 bg-white p-5 shadow-card transition duration-300 hover:-translate-y-2 hover:border-[#7fb4bb] hover:shadow-popover">
              <div class="mb-5 flex items-center justify-between gap-3">
                <span class="grid h-16 w-16 place-items-center rounded-lg border border-[#c8dbdd] bg-[#eef6f6] text-[#1f6672] shadow-sm transition duration-300 group-hover:-translate-y-1 group-hover:border-[#7fb4bb] group-hover:bg-[#e0eff1]">
                  <PackagingIcon name={item.icon} class="h-9 w-9" />
                </span>
                <span class="rounded-md bg-[#eef6f6] px-2.5 py-1 text-xs font-black uppercase tracking-wide text-[#1f6672] transition duration-300 group-hover:bg-[#1f6672] group-hover:text-white">0{index + 1}</span>
              </div>
              <p class="text-xs font-black uppercase tracking-[0.16em] text-neutral-500">{item.step}</p>
              <h3 class="mt-2 min-h-[4.75rem] font-display text-lg font-extrabold uppercase leading-tight text-neutral-900">{item.title}</h3>
              <p class="min-h-[8.25rem] text-sm leading-relaxed text-neutral-600">{item.body}</p>
              <div class="mt-auto border-t border-neutral-200 pt-4 text-sm font-black uppercase tracking-wide text-success">{item.stat}</div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container max-w-wide">
      <div class="mb-12 text-center">
        <h2 class="font-display text-4xl font-extrabold uppercase text-neutral-900 md:text-5xl">Premium Finishes</h2>
        <p class="mt-3 text-neutral-600">Finishing options that give custom boxes a premium retail feel.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {finishes.map((finish) => (
          <a href="/design-support" class="group relative block overflow-hidden rounded-md bg-neutral-900">
            <img
              src={`/images/home/finishes/${finish.image}.webp`}
              alt={`${finish.title} packaging finish`}
              width="768"
              height="341"
              loading="lazy"
              decoding="async"
              class="aspect-[16/9] w-full object-cover opacity-85 transition duration-200 group-hover:scale-[1.03] group-hover:opacity-100"
            />
            <h3 class="absolute bottom-4 left-4 font-display text-xl font-extrabold text-neutral-50">{finish.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section
    class="relative overflow-hidden bg-neutral-900 bg-cover bg-center bg-no-repeat py-16 md:bg-fixed md:py-24"
    style="background-image: url('/images/home/why-choose-parallax-bg.webp');"
  >
    <div class="absolute inset-0 bg-neutral-950/76"></div>
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(9,8,5,0.92)_0%,rgba(9,8,5,0.78)_48%,rgba(9,8,5,0.58)_100%)]"></div>
    <div class="container max-w-wide relative">
      <div class="max-w-4xl">
        <p class="eyebrow">Why Apex</p>
        <h2 class="mt-3 font-display text-4xl font-extrabold text-neutral-50 md:text-6xl">Why Choose Us?</h2>
        <p class="mt-4 max-w-2xl text-lg font-semibold uppercase tracking-wide text-neutral-200">
          Custom packaging support from brief to reorder.
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {reasons.map((reason) => (
          <div class="min-h-[260px] rounded-md border border-white/15 bg-neutral-950/58 p-5 shadow-popover backdrop-blur-sm">
            <span class="mb-5 grid h-[72px] w-[72px] place-items-center rounded-lg border border-white/15 bg-white/10 text-[#8fd0cf] shadow-card">
              <PackagingIcon name={reason.icon} class="h-10 w-10" />
            </span>
            <h3 class="font-display text-xl font-extrabold text-neutral-50">{reason.title}</h3>
            <p class="mt-3 leading-relaxed text-neutral-200">{reason.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container max-w-wide grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <h2 class="font-display text-4xl font-extrabold uppercase text-neutral-900 md:text-5xl">Client Testimonial</h2>
        <p class="mt-3 font-semibold uppercase tracking-wide text-neutral-600">Service that keeps launches moving.</p>
        <div class="mt-8 text-6xl font-black leading-none text-accent">"</div>
        <blockquote class="mt-4 max-w-2xl text-xl font-semibold italic leading-relaxed text-neutral-800">
          Apex helped us move from rough packaging dimensions to a production-ready dieline quickly. The print proof was clear, the material options were practical, and the reorder file saved our team time.
        </blockquote>
        <div class="mt-8 flex items-center gap-4">
          <div class="grid h-16 w-16 place-items-center rounded-md bg-accent font-display text-xl font-extrabold text-neutral-900">PM</div>
          <div>
            <div class="font-bold text-neutral-900">Procurement Manager</div>
            <div class="text-sm text-neutral-500">Canadian consumer goods brand</div>
            <div class="mt-1 text-accent">★★★★★</div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-6">
        <div class="grid grid-cols-2 gap-4">
          {['corrugated-boxes-branded', 'polybags-branded', 'protective-packaging-branded', 'hero-branded-packaging'].map((img) => (
            <img
              src={`/images/home/${img}.webp`}
              alt="Apex Packaging custom packaging example"
              width="1536"
              height="1024"
              loading="lazy"
              decoding="async"
              class="aspect-square w-full rounded-full object-cover shadow-card"
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="quote" class="scroll-mt-28 bg-neutral-100 py-16 md:scroll-mt-32 md:py-24">
    <div class="container max-w-wide">
      <div class="mb-10 max-w-4xl">
        <p class="eyebrow">RFQ desk</p>
        <div class="mt-3 flex flex-wrap items-end gap-x-6 gap-y-3">
          <h2 class="font-display text-4xl font-extrabold uppercase leading-none text-neutral-900 md:text-5xl">Get Custom Quote</h2>
          <span class="mb-1 rounded-md bg-white px-4 py-2 text-sm font-black uppercase tracking-wide text-success shadow-card">Free domestic shipping review</span>
        </div>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-neutral-600">
          Send the package size, material, quantity, and launch timing. Apex reviews the spec and responds with a practical production path.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-12 lg:items-stretch">
        <form class="grid gap-4 rounded-md border border-neutral-200 bg-white p-5 shadow-card md:p-7 lg:col-span-8">
          <div class="grid gap-4 md:grid-cols-3">
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="name" placeholder="Name" />
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="phone" placeholder="Phone No" />
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="email" placeholder="Email Address" />
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="quantity" placeholder="Quantity" />
            <select class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-800 focus:border-accent focus:bg-white" name="material">
              <option>Select Material</option>
              <option>Corrugated</option>
              <option>Kraft paperboard</option>
              <option>Poly film</option>
              <option>Molded pulp</option>
            </select>
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="product" placeholder="Product Name" />
          </div>
          <div class="grid gap-4 md:grid-cols-[1fr_1fr_1fr_0.85fr]">
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="length" placeholder="L" />
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="width" placeholder="W" />
            <input class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="depth" placeholder="D" />
            <select class="h-14 rounded-md border border-neutral-300 bg-neutral-50 px-4 text-base text-neutral-800 focus:border-accent focus:bg-white" name="unit">
              <option>inch</option>
              <option>cm</option>
              <option>mm</option>
            </select>
          </div>
          <textarea class="min-h-40 rounded-md border border-neutral-300 bg-neutral-50 px-4 py-3 text-base text-neutral-900 placeholder:text-neutral-400 focus:border-accent focus:bg-white" name="message" placeholder="Write short message"></textarea>
          <div class="flex flex-wrap items-center gap-4 pt-2">
            <button class="rounded-md bg-accent px-7 py-4 font-black text-neutral-900 transition hover:bg-warning" type="submit">Submit Quote Request</button>
            <p class="max-w-md text-sm font-semibold leading-relaxed text-neutral-500">Attach artwork after the first reply, or include file notes in the message.</p>
          </div>
        </form>

        <aside class="overflow-hidden rounded-md bg-neutral-900 text-neutral-50 shadow-popover lg:col-span-4">
          <div class="border-b border-neutral-700 bg-success px-6 py-7">
            <p class="text-sm font-black uppercase tracking-[0.14em] text-neutral-100">Shop with confidence</p>
            <h3 class="mt-3 font-display text-3xl font-extrabold leading-tight text-neutral-50">Proofed before production.</h3>
          </div>
          <div class="grid gap-5 p-6">
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-md bg-neutral-50 px-4 py-4 text-neutral-900">
                <div class="font-display text-3xl font-extrabold text-accent">24h</div>
                <p class="mt-1 text-sm font-bold leading-snug">Typical RFQ review</p>
              </div>
              <div class="rounded-md bg-neutral-50 px-4 py-4 text-neutral-900">
                <div class="font-display text-3xl font-extrabold text-accent">7-14</div>
                <p class="mt-1 text-sm font-bold leading-snug">Day production window</p>
              </div>
            </div>
            <ul class="grid gap-3 text-sm font-semibold leading-relaxed text-neutral-200">
              <li class="rounded-md border border-neutral-700 px-4 py-3">Secure quote review before order commitment</li>
              <li class="rounded-md border border-neutral-700 px-4 py-3">Material guidance for corrugated, kraft, film, and pulp</li>
              <li class="rounded-md border border-neutral-700 px-4 py-3">Dieline, proof, and reorder files kept on record</li>
            </ul>
            <div class="rounded-md bg-warning px-5 py-4 font-display text-xl font-extrabold leading-tight text-neutral-900">
              Production proof before full run
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container max-w-wide">
      <h2 class="font-display text-3xl font-extrabold text-neutral-900 md:text-4xl">Get Your Custom Boxes with Logo for Every Product at Wholesale Rate</h2>
      <p class="mt-5 max-w-5xl text-lg leading-relaxed text-neutral-600">
        Apex Packaging Solutions manufactures custom printed boxes, mailers, bags, trays, sleeves, and protective packaging for brands that need product-ready packaging without long overseas timelines. Choose a category, send the product dimensions, and Apex will help select material, structure, print method, finishing, and shipment timing.
      </p>
    </div>
  </section>

  <section class="bg-neutral-900 py-10 text-neutral-50">
    <div class="container max-w-wide grid gap-4 md:grid-cols-5">
      {categories.slice(-5).map((cat) => (
        <a href={cat.href} class="text-center">
          <img
            src={`/images/home/categories/${cat.image}.webp`}
            alt={`${cat.title} product packaging`}
            width="418"
            height="418"
            loading="lazy"
            decoding="async"
            class="aspect-square w-full object-cover"
          />
          <span class="mt-3 block font-display text-lg font-bold">{cat.title}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
