            srcset={responsiveImageSrcset(cat.image, [320, 500, 620])}
            sizes="(max-width: 767px) 48vw, 13rem"
            alt={cat.alt}
            width="418"
            height="418"
            loading="lazy"
            decoding="async"
            class="aspect-square w-full rounded-md object-cover md:rounded-none"
          />
          <span class="mt-3 block font-display text-sm font-bold md:text-lg">{cat.title}</span>
        </a>
      ))}
    </div>
  </section>
