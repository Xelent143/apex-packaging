---
import BaseLayout from '../layouts/BaseLayout.astro';
import PackagingIcon from '../components/ui/PackagingIcon.astro';

const categoryCards = [
  {
    title: 'Rigid Boxes',
    subtitle: 'Premium & luxury boxes',
    href: '/industries/rigid-boxes',
    image: '/images/home/categories/rigid-boxes.webp',
    alt: 'Premium rigid box packaging with gold detailing'
  },
  {
    title: 'Corrugated Boxes',
    subtitle: 'Durable & reliable',
    href: '/services/corrugated-boxes',
    image: '/images/apex-update/materials/corrugated-boxes.webp',
    alt: 'Custom corrugated shipping box'
  },
  {
    title: 'Mailer Boxes',
    subtitle: 'E-commerce & subscription',
    href: '/services/mailer-boxes',
    image: '/images/home/mailer-boxes-branded.webp',
    alt: 'Premium custom printed mailer box'
  },
  {
    title: 'Pouches & Bags',
    subtitle: 'Flexible & stand-up pouches',
    href: '/industries/custom-mylar-bags',
    image: '/images/home/categories/custom-mylar-bags.webp',
    alt: 'Custom printed stand-up pouch packaging'
  },
  {
    title: 'Custom Printed Boxes',
    subtitle: 'High-quality printing',
    href: '/industries/custom-tuck-boxes',
    image: '/images/home/categories/custom-tuck-boxes.webp',
    alt: 'Custom printed retail tuck boxes'
  },
  {
    title: 'CBD Packaging',
    subtitle: 'Compliant & secure',
    href: '/services/cbd-boxes',
    image: '/images/home/categories/cbd-gift-boxes.webp',
    alt: 'Premium CBD gift packaging with fitted inserts'
  }
];

const serviceBenefits = [
  { title: 'Custom Made', body: 'Tailored to your brand', icon: 'custom-spec' },
  { title: 'Low Minimums', body: 'Perfect for any size', icon: 'low-moq' },
  { title: 'Eco-Friendly', body: 'Sustainable options', icon: 'sustainable-materials' },
  { title: 'Expert Support', body: "We're here to help", icon: 'design-support' },
  { title: 'Global Shipping', body: 'Delivering worldwide', icon: 'domestic-shipping' }
];

const industries = [
  { title: 'Beauty & Cosmetics', href: '/industries/cosmetic-boxes', icon: 'printing-quality' },
  { title: 'Food & Beverage', href: '/industries/food-boxes', icon: 'sample-run' },
  { title: 'Health & Wellness', href: '/industries/health-boxes', icon: 'sustainable-materials' },
  { title: 'E-commerce & Retail', href: '/industries/retail-boxes', icon: 'domestic-shipping' },
  { title: 'CBD & Cannabis', href: '/services/cbd-boxes', icon: 'premium-finishes' },
  { title: 'Electronics', href: '/industries/electronics-boxes', icon: 'procurement-specs' },
  { title: 'Apparel & Accessories', href: '/industries/apparel-boxes', icon: 'custom-size-shape' },
  { title: 'More Industries', href: '/industries', icon: 'quote-review' }
];

const proofStats = [
  { value: '10+', label: 'Years of Experience', icon: 'sample-run' },
  { value: '25K+', label: 'Projects Completed', icon: 'quote-review' },
  { value: '98%', label: 'Customer Satisfaction', icon: 'design-support' },
  { value: '7 Days', label: 'Fastest Turnaround', icon: 'production-window' },
  { value: '100+', label: 'Materials & Finishes', icon: 'premium-finishes' }
];

const testimonials = [
  {
    quote: 'The quality is exceptional, the communication is clear, and our launch packaging arrived exactly as approved.',
    role: 'Marketing Director',
    company: 'Canadian beauty brand',
    initials: 'MD'
  },
  {
    quote: 'From dieline to delivery, the team made a complex custom box feel simple. The finished presentation elevated our brand.',
    role: 'Founder',
    company: 'Wellness product company',
    initials: 'FO'
  },
  {
    quote: 'Reliable, professional, and practical about materials, timelines, and cost. Apex has become a trusted packaging partner.',
    role: 'Operations Lead',
    company: 'Retail products company',
    initials: 'OL'
  }
];
---

<BaseLayout
  title="Custom Packaging Canada | Apex Packaging"
  description="Premium custom boxes, mailers, pouches, inserts, and retail packaging with low minimums, fast turnaround, and expert design support from Apex Packaging."
>
  <section class="home-hero relative isolate overflow-hidden bg-[#061a2e] text-white">
    <img
      src="/images/apex-update/banners/banner-1.webp"
      srcset="/images/apex-update/banners/banner-1-721.webp 721w, /images/apex-update/banners/banner-1-1080.webp 1080w, /images/apex-update/banners/banner-1-1442.webp 1442w"
      sizes="(max-width: 767px) 100vw, 70vw"
      alt="Premium custom boxes, pouches, mailers, and retail packaging"
      width="2172"
      height="724"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="absolute inset-y-0 right-0 -z-20 h-full w-full object-cover object-[67%_center] opacity-60 md:w-[72%] md:opacity-70"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,#061a2e_0%,#061a2e_38%,rgba(6,26,46,0.9)_55%,rgba(6,26,46,0.28)_100%)]"></div>
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_88%_25%,rgba(190,145,30,0.18),transparent_34%)]"></div>

    <div class="container max-w-wide grid min-h-[34rem] items-center py-14 md:min-h-[38rem] md:grid-cols-12 md:py-20 lg:min-h-[40rem]">
      <div class="max-w-3xl md:col-span-7 lg:col-span-6">
        <p class="inline-flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.18em] text-[#e1b84d]">
          <span class="h-px w-9 bg-[#e1b84d]"></span>
          Premium packaging. Powerful impressions.
        </p>
        <h1 class="home-serif mt-5 text-[2.8rem] font-semibold leading-[0.98] tracking-[-0.035em] text-white sm:text-6xl lg:text-[4.8rem]">
          Custom Packaging <span class="block text-[#d8ad3d]">That Elevates</span> Your Brand
        </h1>
        <p class="mt-6 max-w-xl text-base font-medium leading-relaxed text-white/82 md:text-lg">
          High-quality custom boxes and packaging solutions designed to protect, impress, and inspire.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="#packaging-categories" class="home-gold-button">Explore Packaging <span aria-hidden="true">→</span></a>
          <a href="/contact" class="home-outline-button">
            <PackagingIcon name="quote-review" class="h-5 w-5" /> Request a Quote
          </a>
        </div>
        <div class="mt-8 grid max-w-2xl gap-4 border-t border-white/15 pt-5 sm:grid-cols-3">
          {[
            ['Premium Quality', 'Built to impress', 'printing-quality'],
            ['Fast Turnaround', 'As fast as 7 days', 'production-window'],
            ['Secure Delivery', 'Protected packaging', 'domestic-shipping']
          ].map(([title, body, icon]) => (
            <div class="flex items-center gap-3">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-[#d8ad3d] text-[#e1b84d]">
                <PackagingIcon name={icon} class="h-6 w-6" />
              </span>
              <span>
                <strong class="block text-xs font-extrabold text-white">{title}</strong>
                <span class="block text-[0.68rem] text-white/65">{body}</span>
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 -mt-7 px-4">
    <div class="mx-auto grid max-w-wide overflow-hidden rounded-xl border border-[#dfd3b6] bg-[#fffdf8] shadow-[0_20px_45px_rgba(15,32,50,0.14)] sm:grid-cols-2 lg:grid-cols-5">
      {serviceBenefits.map((item) => (
        <div class="flex min-h-28 items-center gap-4 border-b border-[#e9dfca] px-5 py-5 last:border-b-0 sm:[&:nth-child(odd)]:border-r lg:border-b-0 lg:border-r lg:last:border-r-0">
          <span class="grid h-11 w-11 shrink-0 place-items-center text-[#b78716]">
            <PackagingIcon name={item.icon} class="h-10 w-10" />
          </span>
          <span>
            <strong class="block font-display text-sm font-extrabold text-[#102337]">{item.title}</strong>
            <span class="mt-1 block text-xs text-neutral-500">{item.body}</span>
          </span>
        </div>
      ))}
    </div>
  </section>

  <section id="packaging-categories" class="scroll-mt-28 bg-[#f8f4ec] pb-16 pt-20 md:pb-24 md:pt-24">
    <div class="container max-w-wide">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="home-kicker">Shop by category</p>
          <h2 class="home-serif mt-2 text-3xl font-semibold leading-tight text-[#102337] md:text-4xl">Find the Perfect Packaging</h2>
        </div>
        <a href="/industries" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md border border-[#b78716] px-5 text-xs font-extrabold uppercase tracking-wide text-[#8a650c] transition hover:bg-[#b78716] hover:text-white">
          View all categories <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
        {categoryCards.map((category) => (
          <a href={category.href} class="group overflow-hidden rounded-xl border border-[#e4dac5] bg-white shadow-[0_8px_24px_rgba(15,35,55,0.06)] transition duration-300 hover:-translate-y-1.5 hover:border-[#c99b2a] hover:shadow-[0_18px_35px_rgba(15,35,55,0.13)]">
            <div class="overflow-hidden bg-[#f1ede4] p-2">
              <img
                src={category.image}
                alt={category.alt}
                width="620"
                height="620"
                loading="lazy"
                decoding="async"
                class="aspect-square w-full rounded-lg object-cover transition duration-500 group-hover:scale-[1.035]"
              />
            </div>
            <div class="px-3 pb-4 pt-3 text-center">
              <h3 class="font-display text-sm font-extrabold text-[#102337]">{category.title}</h3>
              <p class="mt-1 text-[0.7rem] text-neutral-500">{category.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-[#e5dbc7] bg-[#fffdf8] py-14 md:py-20">
    <div class="container max-w-wide">
      <p class="home-kicker">Industries we serve</p>
      <h2 class="home-serif mt-2 text-3xl font-semibold text-[#102337] md:text-4xl">Custom Packaging Solutions for Every Industry</h2>
      <div class="mt-9 grid grid-cols-2 gap-y-8 sm:grid-cols-4 lg:grid-cols-8">
        {industries.map((industry) => (
          <a href={industry.href} class="group flex min-h-28 flex-col items-center justify-center gap-3 border-r border-[#e8dfce] px-3 text-center last:border-r-0 hover:text-[#9a7110]">
            <span class="text-[#b78716] transition duration-300 group-hover:-translate-y-1">
              <PackagingIcon name={industry.icon} class="h-11 w-11" />
            </span>
            <span class="text-xs font-bold leading-snug text-[#203348] transition group-hover:text-[#9a7110]">{industry.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#f8f4ec] py-16 md:py-24">
    <div class="container max-w-wide">
      <div class="overflow-hidden rounded-2xl border border-[#ded2b9] bg-[#fffdf8] shadow-[0_18px_45px_rgba(15,35,55,0.08)] lg:grid lg:grid-cols-[1.15fr_2.35fr]">
        <div class="bg-[linear-gradient(145deg,#fffaf0,#f3ead9)] p-7 md:p-10">
          <p class="home-kicker">Why choose Apex Packaging?</p>
          <h2 class="home-serif mt-3 text-3xl font-semibold leading-tight text-[#102337] md:text-4xl">Quality You Can See. Service You Can Trust.</h2>
          <p class="mt-4 text-sm leading-relaxed text-neutral-600">
            Premium materials, experienced guidance, and dependable production for packaging that protects your product and strengthens your brand.
          </p>
          <a href="/about" class="mt-7 inline-flex min-h-11 items-center gap-3 rounded-md bg-[#071c32] px-5 text-xs font-extrabold uppercase tracking-wide text-white transition hover:bg-[#b78716]">
            Learn more about us <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="grid grid-cols-2 border-t border-[#e2d7c1] lg:grid-cols-5 lg:border-l lg:border-t-0">
          {proofStats.map((stat) => (
            <div class="flex min-h-44 flex-col items-center justify-center border-b border-r border-[#e6dcc9] px-4 py-7 text-center last:border-r-0 lg:min-h-full lg:border-b-0">
              <span class="text-[#b78716]"><PackagingIcon name={stat.icon} class="h-10 w-10" /></span>
              <strong class="home-serif mt-4 text-3xl font-semibold text-[#102337] md:text-4xl">{stat.value}</strong>
              <span class="mt-2 max-w-24 text-xs font-semibold leading-snug text-neutral-600">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#fffdf8] py-16 md:py-24">
    <div class="container max-w-wide">
      <div class="text-center">
        <p class="home-kicker">What our clients say</p>
        <h2 class="home-serif mt-2 text-3xl font-semibold text-[#102337] md:text-4xl">Trusted by Brands Worldwide</h2>
      </div>
      <div class="mt-9 grid gap-5 lg:grid-cols-3">
        {testimonials.map((testimonial) => (
          <article class="rounded-xl border border-[#e3d9c4] bg-white p-6 shadow-[0_10px_30px_rgba(15,35,55,0.07)] md:p-7">
            <div class="text-sm tracking-[0.16em] text-[#c39422]" aria-label="Five stars">★★★★★</div>
            <blockquote class="mt-5 text-sm leading-relaxed text-neutral-600">“{testimonial.quote}”</blockquote>
            <div class="mt-6 flex items-center gap-3 border-t border-[#eee6d8] pt-5">
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-[#071c32] text-xs font-extrabold text-[#e1b84d]">{testimonial.initials}</span>
              <span>
                <strong class="block text-sm font-extrabold text-[#102337]">{testimonial.role}</strong>
                <span class="block text-xs text-neutral-500">{testimonial.company}</span>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="relative isolate overflow-hidden bg-[#061a2e] py-14 text-white md:py-16">
    <img
      src="/images/home/hero-packaging-banner-apex.webp"
      alt="Apex branded custom packaging collection"
      width="1774"
      height="887"
      loading="lazy"
      decoding="async"
      class="absolute inset-y-0 left-0 -z-20 h-full w-full object-cover object-[72%_center] opacity-45 md:w-[42%] md:object-[70%_center] md:opacity-75"
    />
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(6,26,46,0.2),#061a2e_42%,#061a2e)]"></div>
    <div class="container max-w-wide grid gap-10 md:grid-cols-[0.72fr_1.35fr_0.85fr] md:items-center">
      <div class="hidden md:block"></div>
      <div>
        <h2 class="home-serif text-3xl font-semibold text-white md:text-5xl">Ready to Elevate Your Brand?</h2>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/75 md:text-base">Let's create packaging that protects, impresses, and drives results.</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="home-gold-button">Get Your Custom Quote <span aria-hidden="true">→</span></a>
          <a href="tel:+19055951634" class="home-outline-button">Call 905 595 1634</a>
        </div>
      </div>
      <ul class="space-y-4 text-sm font-semibold text-white/85">
        {['Free Design Support', 'No Obligation Quote', 'Fast & Easy Process'].map((item) => (
          <li class="flex items-center gap-3">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-[#d8ad3d] text-[#e1b84d]">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .home-serif {
    font-family: Georgia, 'Times New Roman', serif;
    letter-spacing: -0.025em;
  }

  .home-kicker {
    color: #a97c12;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .home-gold-button,
  .home-outline-button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    border-radius: 0.38rem;
    padding: 0.75rem 1.35rem;
    font-family: Archivo, sans-serif;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .home-gold-button {
    background: linear-gradient(180deg, #e4b842 0%, #b77f06 100%);
    color: white;
    box-shadow: 0 10px 26px rgba(188, 132, 8, 0.25);
  }

  .home-outline-button {
    border: 1px solid rgba(255, 255, 255, 0.7);
    color: white;
  }

  .home-gold-button:hover,
  .home-outline-button:hover {
    transform: translateY(-2px);
  }

  .home-outline-button:hover {
    border-color: #e1b84d;
    background: rgba(225, 184, 77, 0.12);
  }

  @media (max-width: 639px) {
    .home-gold-button,
    .home-outline-button {
      width: 100%;
    }
  }
</style>
