---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import { buildBreadcrumbSchema } from '../../lib/schema';

const posts = [
  { slug: 'stretch-film-vs-shrink-film-pallet-protection', title: 'Stretch film vs shrink film — which one protects your pallet?', description: 'A practical buyer guide to stretch film and shrink film in Canada: manual vs machine wrap, load containment, heat requirements, and the RFQ details that prevent pallet damage.', date: '2026-06-14', read: '7 min' },
  { slug: 'gaylord-boxes-bulk-containers-procurement-guide', title: 'Gaylord boxes and bulk containers — a procurement guide', description: 'A practical buyer guide to Gaylord boxes in Canada: stock footprints, octagonal vs square formats, liner questions, stacking risks, and the RFQ details that speed up quoting.', date: '2026-06-13', read: '7 min' },
  { slug: 'custom-shipping-boxes-heavy-products-ect-flute-pallet-stacking', title: 'Custom shipping boxes for heavy products — ECT, flute, and pallet stacking', description: 'A practical guide to heavy-product shipping boxes in Canada: when to move to ECT-44 or double-wall, how flute choice affects compression, and what pallet details belong in the RFQ.', date: '2026-06-12', read: '7 min' },
  { slug: 'low-moq-custom-packaging-100-500-units-without-waste', title: 'Low MOQ custom packaging — how to order 100-500 units without waste', description: 'A practical guide to low-MOQ custom packaging in Canada: when 100-500 unit runs work, what pushes costs up, and what specs buyers should send first.', date: '2026-06-11', read: '7 min' },
  { slug: 'fsc-certified-corrugated-boxes-buyers-verify', title: 'FSC-certified corrugated boxes — what buyers should verify', description: 'A procurement guide to FSC-certified corrugated boxes in Canada: chain-of-custody, board spec, artwork marks, recycled-content questions, and the paperwork to request.', date: '2026-06-11', read: '7 min' },
  { slug: 'custom-mailer-boxes-ecommerce-print-inserts-moq', title: 'Custom mailer boxes for ecommerce — print, inserts, and MOQ', description: 'A practical buyer guide to custom mailer boxes in Canada: board choice, print coverage, insert options, sample flow, and the specs that control MOQ.', date: '2026-06-10', read: '7 min' },
  { slug: 'anti-static-polybags-esd-protection', title: 'Anti-static polybags — when electronics buyers need ESD protection', description: 'Compare standard poly, pink anti-static, and static-shielding bags by product sensitivity, bag gauge, and the rest of the packout system.', date: '2026-06-09', read: '7 min' },
  { slug: 'rsc-boxes-vs-die-cut-boxes', title: 'RSC boxes vs die-cut boxes — which style fits your product?', description: 'Compare RSC boxes and die-cut boxes by structure, MOQ, setup, packing speed, and when custom conversion lowers total packaging cost.', date: '2026-06-09', read: '7 min' },
  { slug: 'custom-corrugated-boxes-canada-moq-lead-time-specs', title: 'Custom corrugated boxes in Canada — MOQ, lead time, and specs', description: 'How to buy custom corrugated boxes in Canada: box styles, ECT grades, MOQs, 7-14 day lead times, FSC options, and the specs buyers should send for a quote.', date: '2026-06-09', read: '8 min' },
  { slug: 'ect-explained', title: 'ECT-32 vs ECT-44 — what the corrugated rating actually tells you', description: 'A working guide to corrugated strength ratings, when to choose which, with weight examples.', date: '2026-06-02', read: '6 min' },
  { slug: 'rsc-vs-fol-box-styles', title: 'RSC, FOL, or telescoping — picking the right box style', description: 'A practical guide to Regular Slotted Cartons, Full Overlap Slotted Cartons, and telescoping boxes.', date: '2026-06-02', read: '5 min' },
  { slug: 'poly-bag-thickness-guide', title: 'Poly bag thickness — when 1.5 mil is enough and when you need 4', description: 'Practical guide to polybag gauges from 1.0 mil to 6.0 mil. Match thickness to product weight, edge sharpness, and stacking pattern.', date: '2026-06-02', read: '7 min' }
];
const breadcrumb = buildBreadcrumbSchema([{name:'Home',url:'/'},{name:'Blog',url:'/blog'}]);
---
<BaseLayout
  title="Packaging Knowledge Base — Specs, Materials, Best Practices"
  description="Articles on corrugated strength ratings, box styles, polybag thickness, and other practical packaging specifications from Apex's design and engineering team."
  schemaBlocks={[breadcrumb]}
>
  <PageHeader
    eyebrow="Knowledge base"
    heading="Practical guides for buying custom packaging in Canada."
    lead="Articles for procurement teams and operations buyers — corrugated ratings, polybag specs, and the trade-offs that determine which packaging actually fits the job."
  />
  <section class="py-16 md:py-24">
    <div class="container max-w-default">
      <div class="space-y-10 md:space-y-14">
        {posts.map((p) => (
          <article class="pb-10 md:pb-14 border-b border-neutral-200 last:border-0">
            <div class="flex items-center gap-4 mb-3 text-xs uppercase tracking-wider text-neutral-500 font-medium">
              <time>{p.date}</time>
              <span>·</span>
              <span>{p.read} read</span>
            </div>
            <h2 class="font-display font-bold text-2xl md:text-3xl text-neutral-900 leading-tight mb-3 max-w-3xl">
              <a class="hover:text-accent transition-colors" href={`/blog/${p.slug}`}>{p.title}</a>
            </h2>
            <p class="text-[1.0625rem] text-neutral-600 leading-relaxed max-w-3xl">{p.description}</p>
            <a class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-accent" href={`/blog/${p.slug}`}>Read article →</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
