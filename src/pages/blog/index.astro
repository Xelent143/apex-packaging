  { slug: 'custom-shipping-boxes-heavy-products-ect-flute-pallet-stacking', title: 'Custom shipping boxes for heavy products — ECT, flute, and pallet stacking', description: 'A practical guide to heavy-product shipping boxes in Canada: when to move to ECT-44 or double-wall, how flute choice affects compression, and what pallet details belong in the RFQ.', date: '2026-06-12', read: '7 min' },
