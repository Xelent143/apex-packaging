  { slug: 'fsc-certified-corrugated-boxes-buyers-verify', title: 'FSC-certified corrugated boxes — what buyers should verify', description: 'A procurement guide to FSC-certified corrugated boxes in Canada: chain-of-custody, board spec, artwork marks, recycled-content questions, and the paperwork to request.', date: '2026-06-11', read: '7 min' },
  { slug: 'custom-mailer-boxes-ecommerce-print-inserts-moq', title: 'Custom mailer boxes for ecommerce — print, inserts, and MOQ', description: 'A practical buyer guide to custom mailer boxes in Canada: board choice, print coverage, insert options, sample flow, and the specs that control MOQ.', date: '2026-06-10', read: '7 min' },
  { slug: 'anti-static-polybags-esd-protection', title: 'Anti-static polybags — when electronics buyers need ESD protection', description: 'Compare standard poly, pink anti-static, and static-shielding bags by product sensitivity, bag gauge, and the rest of the packout system.', date: '2026-06-09', read: '7 min' },
  { slug: 'rsc-boxes-vs-die-cut-boxes', title: 'RSC boxes vs die-cut boxes — which style fits your product?', description: 'Compare RSC boxes and die-cut boxes by structure, MOQ, setup, packing speed, and when custom conversion lowers total packaging cost.', date: '2026-06-09', read: '7 min' },
  { slug: 'custom-corrugated-boxes-canada-moq-lead-time-specs', title: 'Custom corrugated boxes in Canada — MOQ, lead time, and specs', description: 'How to buy custom corrugated boxes in Canada: box styles, ECT grades, MOQs, 7-14 day lead times, FSC options, and the specs buyers should send for a quote.', date: '2026-06-09', read: '8 min' },
