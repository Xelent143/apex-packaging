  { slug: 'custom-foam-inserts-corrugated-alone-not-enough', title: 'Custom foam inserts — when corrugated alone is not enough', description: 'A practical buyer guide to custom foam inserts in Canada: when corrugated needs internal cushioning, which foam grade fits the product, and what to send in the RFQ.', date: '2026-06-18', read: '7 min' },
  { slug: 'apparel-packaging-boxes-garment-bags-mailers', title: 'Apparel packaging - boxes, garment bags, and branded mailers', description: 'A practical buyer guide to apparel packaging in Canada and the USA: fold size, returns, hang holes, and branded unboxing, quote details, and internal packaging decisions before production.', date: '2026-06-17', read: '7 min' },
