---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import { siteConfig } from '../site.config';
import { buildBreadcrumbSchema } from '../lib/schema';
const breadcrumb = buildBreadcrumbSchema([{name:'Home',url:'/'},{name:'Contact',url:'/contact'}]);
---
<BaseLayout
  title="Contact Apex Packaging Solutions — Request a Custom Packaging Quote"
  description="Send product dimensions, target MOQ, and lead time. Apex returns a quote within one business day across all Canadian provinces."
  schemaBlocks={[breadcrumb]}
>
  <PageHeader
    eyebrow="Contact"
    heading="Send your packaging spec. Get a quote within one business day."
    lead="For the fastest reply, include product dimensions, target MOQ, lead time, sustainability requirements (if any), and brand assets if it is a printed product. Vector logos preferred (AI/EPS/PDF)."
  />

  <section class="py-12 md:py-24">
    <div class="container max-w-wide">
      <div class="grid gap-8 md:grid-cols-12 md:gap-12">
        <aside class="space-y-4 md:col-span-4 md:space-y-6">
          <div>
            <h3 class="font-display font-semibold text-lg text-neutral-900 mb-3">Direct contact</h3>
            <ul class="space-y-2 text-[0.9375rem] text-neutral-700">
              <li><a class="break-all text-accent hover:underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
              <li>{siteConfig.formattedAddress}</li>
            </ul>
          </div>
          <div class="rounded-md bg-neutral-100 p-5 md:p-6">
            <h3 class="font-display font-semibold text-lg text-neutral-900 mb-3">Typical response</h3>
            <p class="text-[0.9375rem] text-neutral-700 leading-relaxed">One business day on most quotes. Urgent or rush requests are typically same-day if received before 11am ET.</p>
          </div>
          <div class="rounded-md bg-neutral-100 p-5 md:p-6">
            <h3 class="font-display font-semibold text-lg text-neutral-900 mb-3">NDAs</h3>
            <p class="text-[0.9375rem] text-neutral-700 leading-relaxed">Standard NDA available before any spec discussion. Mutual-NDA on request.</p>
          </div>
        </aside>

        <form class="space-y-5 rounded-md border border-neutral-200 bg-white p-4 shadow-card md:col-span-8 md:p-7" action="/api/quote" method="POST">
          <input type="hidden" name="source" value="Contact Page" />
          <input type="hidden" name="redirectTo" value="/thank-you" />
          <label class="hidden" aria-hidden="true">
            Website
            <input name="website" tabindex="-1" autocomplete="off" />
          </label>
          <div class="grid gap-4 md:grid-cols-2 md:gap-5">
            <label class="block">
              <span class="block text-sm font-medium text-neutral-800 mb-2">Name <span class="text-accent">*</span></span>
              <input required name="name" type="text" class="h-[3.25rem] w-full rounded-md border-2 border-neutral-300 px-4 outline-none transition-colors focus:border-accent" />
            </label>
            <label class="block">
              <span class="block text-sm font-medium text-neutral-800 mb-2">Company <span class="text-accent">*</span></span>
              <input required name="company" type="text" class="h-[3.25rem] w-full rounded-md border-2 border-neutral-300 px-4 outline-none transition-colors focus:border-accent" />
            </label>
            <label class="block">
              <span class="block text-sm font-medium text-neutral-800 mb-2">Email <span class="text-accent">*</span></span>
              <input required name="email" type="email" class="h-[3.25rem] w-full rounded-md border-2 border-neutral-300 px-4 outline-none transition-colors focus:border-accent" />
            </label>
            <label class="block">
              <span class="block text-sm font-medium text-neutral-800 mb-2">Phone</span>
              <input name="phone" type="tel" class="h-[3.25rem] w-full rounded-md border-2 border-neutral-300 px-4 outline-none transition-colors focus:border-accent" />
            </label>
          </div>
          <label class="block">
            <span class="block text-sm font-medium text-neutral-800 mb-2">Project type</span>
            <select name="type" class="h-[3.25rem] w-full rounded-md border-2 border-neutral-300 bg-neutral-50 px-4 outline-none transition-colors focus:border-accent">
              <option>Request for quote (RFQ)</option>
              <option>Sample request</option>
              <option>Design help only</option>
              <option>Bulk / blanket PO</option>
              <option>General inquiry</option>
            </select>
          </label>
          <label class="block">
            <span class="block text-sm font-medium text-neutral-800 mb-2">Project details <span class="text-accent">*</span></span>
            <textarea required name="details" rows="5" placeholder="Product type, dimensions, target MOQ, lead time, sustainability requirements" class="w-full resize-y rounded-md border-2 border-neutral-300 px-4 py-3 outline-none transition-colors focus:border-accent" />
          </label>
          <button type="submit" class="btn-primary">Send for a quote</button>
          <p class="text-xs text-neutral-500">Your request goes directly to the Apex quote inbox.</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
